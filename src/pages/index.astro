---
import Layout from '../layouts/Layout.astro';

const tracks = [
  { year: '2006', title: 'Departare', feat: 'feat. Loredana', note: 'Debut' },
  { year: '2010', title: 'Lovaman', feat: 'EP', note: 'First EP' },
  { year: '2012', title: 'Push It', feat: 'feat. Stella' },
  { year: '2013', title: 'Amândoi' },
  { year: '2013', title: 'Panama', note: '225M+ views', highlight: true },
  { year: '2014', title: 'Andale' },
  { year: '2015', title: 'Gândesc cu voce tare' },
  { year: '2017', title: 'Bună, Marie!', feat: 'feat. Uddi' },
  { year: '2018', title: 'Allegro Ventigo', feat: 'feat. Dan Bălan', highlight: true },
  { year: '2021', title: 'Copacul', feat: 'feat. Theo Rose' },
  { year: '2023', title: 'Lato Lato Song', feat: 'feat. Sean Al' },
  { year: '2025', title: 'Gypsy Reggae', feat: 'EP', note: 'New genre. New era.', highlight: true },
];

// Per artist: socials/media/downloads. Replace # placeholders with real URLs/IDs when delivered.
const roster = [
  {
    slug: 'matteo',
    name: 'Matteo',
    tag: 'Founder',
    tagline: 'Two decades. Hit after hit.',
    bio: 'Founder of Mattman Music. Almost two decades of hits — debut "Departare" (2006, with Loredana). Most viral single "Panama" — 225M+ views, going global on TikTok across Asia. Latest venture: a self-coined fusion genre, Gypsy Reggae, with King Kong, Anthony B, Loyal Flames and Johny Romano.',
    photo: '/images/matteo/portrait-md.jpg',
    photoAlt: '/images/matteo/portrait-md.jpg',
    socials: {
      instagram: '#',
      youtube: '#',
      spotify: '#',
      tiktok: '#',
    },
    media: [
      { type: 'youtube', id: '', title: 'Panama' },
      { type: 'youtube', id: '', title: 'Allegro Ventigo' },
    ],
    downloads: [
      { label: 'Logo (PNG)', href: '#' },
      { label: 'Press Photo', href: '#' },
      { label: 'Bio (PDF)', href: '#' },
    ],
  },
  {
    slug: 'andrei',
    name: 'Andrei Bănuță',
    tagline: 'An artist of contrasts.',
    bio: 'One of the most in-demand voices today. Songwriting that alternates between deep, meaningful lyrics and vibrant, playful songs. Best known for "Suflet de Bagabond" (90M+ views) and "Old Friend" with Vescan — over 10 weeks atop the Media Forest Chart.',
    photo: '/images/roster/andrei.jpg',
    photoAlt: '/images/roster/andrei-2.jpg',
    socials: {
      instagram: '#',
      youtube: '#',
      spotify: '#',
      tiktok: '#',
    },
    media: [
      { type: 'youtube', id: '', title: 'Suflet de Bagabond' },
      { type: 'youtube', id: '', title: 'Old Friend (w/ Vescan)' },
    ],
    downloads: [
      { label: 'Logo (PNG)', href: '#' },
      { label: 'Press Photo', href: '#' },
      { label: 'Bio (PDF)', href: '#' },
    ],
  },
  {
    slug: 'georgiana',
    name: 'Georgiana Neagu',
    tagline: 'The new wave of balkan pop.',
    bio: 'A new wave of Romanian balkan pop. Contemporary sound and relatable lyrics that connect with a young audience nationwide. "M-am Îndrăgostit de Tine (Vreau să facem o fetiță)" — viral on TikTok, 2.2M+ views on YouTube.',
    photo: '/images/roster/georgiana.jpg',
    photoAlt: '/images/roster/georgiana-2.jpg',
    socials: {
      instagram: '#',
      youtube: '#',
      spotify: '#',
      tiktok: '#',
    },
    media: [
      { type: 'youtube', id: '', title: 'M-am Îndrăgostit de Tine' },
    ],
    downloads: [
      { label: 'Logo (PNG)', href: '#' },
      { label: 'Press Photo', href: '#' },
      { label: 'Bio (PDF)', href: '#' },
    ],
  },
  {
    slug: 'emily',
    name: 'Emily Istrate',
    tagline: 'Beautiful, talented, charismatic.',
    bio: 'Singer, songwriter, actress from the Republic of Moldova. International recognition with "If You Want To" and "Panic" — UK Pop Club Charts #4 and #5. 2023 saw her climb the top of major Romanian charts with "Bye Bye Boy" and "În Mintea Mea".',
    photo: '/images/roster/emily.jpg',
    photoAlt: '/images/roster/emily-2.jpg',
    socials: {
      instagram: '#',
      youtube: '#',
      spotify: '#',
      tiktok: '#',
    },
    media: [
      { type: 'youtube', id: '', title: 'If You Want To' },
      { type: 'youtube', id: '', title: 'În Mintea Mea' },
    ],
    downloads: [
      { label: 'Logo (PNG)', href: '#' },
      { label: 'Press Photo', href: '#' },
      { label: 'Bio (PDF)', href: '#' },
    ],
  },
];
---
<Layout>
  <!-- NAV -->
  <nav class="nav">
    <a href="#top" class="nav-logo hover-target" data-magnetic="0.4">
      <img src="/images/mattman/logo-black.png" alt="Mattman Music" class="nav-logo-img" />
    </a>
    <ul class="nav-links mono">
      <li><a href="#manifest">Manifest</a></li>
      <li><a href="#roster">Roster</a></li>
      <li><a href="#catalog">Catalog</a></li>
      <li><a href="#booking">Booking</a></li>
    </ul>
  </nav>

  <!-- HERO — sonic-echo composition -->
  <section class="hero" id="top">
    <div class="hero-sonic" data-hero-sonic>
      <div class="hero-echo-wrap" data-hero-mark>
        <span class="hero-echo hero-echo-4" aria-hidden="true">MATTMAN</span>
        <span class="hero-echo hero-echo-3" aria-hidden="true">MATTMAN</span>
        <span class="hero-echo hero-echo-2" aria-hidden="true">MATTMAN</span>
        <span class="hero-echo hero-echo-1" aria-hidden="true">MATTMAN</span>
        <h1 class="hero-main" aria-label="Mattman Music">
          <span class="hm-mask"><span class="hm-char">M</span></span>
          <span class="hm-mask"><span class="hm-char">A</span></span>
          <span class="hm-mask"><span class="hm-char">T</span></span>
          <span class="hm-mask"><span class="hm-char">T</span></span>
          <span class="hm-mask"><span class="hm-char">M</span></span>
          <span class="hm-mask"><span class="hm-char">A</span></span>
          <span class="hm-mask"><span class="hm-char">N</span></span>
        </h1>
      </div>

      <div class="hero-sub" data-reveal>
        <span class="hero-sub-rule" aria-hidden="true"></span>
        <span class="hero-sub-text">
          <em class="hero-sub-italic">music</em>
          <span class="hero-sub-mono mono">est. 2006</span>
        </span>
        <span class="hero-sub-rule" aria-hidden="true"></span>
      </div>

      <span class="hero-corner hero-corner-br mono">
        <span>Scroll</span>
        <span class="hero-corner-arrow">↓</span>
      </span>
    </div>
  </section>


  <!-- STATS / NUMBERS -->
  <section class="stats">
    <div class="container stats-grid">
      <div class="stat" data-reveal>
        <div class="stat-num display"><span data-counter="2" data-suffix="" data-decimals="0">0</span><span class="stat-plus">+</span></div>
        <div class="stat-label mono">Decades<br>of hits</div>
      </div>
      <div class="stat" data-reveal>
        <div class="stat-num display"><span data-counter="225" data-suffix="M" data-decimals="0">0</span><span class="stat-plus">+</span></div>
        <div class="stat-label mono">Views on Panama<br>across platforms</div>
      </div>
      <div class="stat" data-reveal>
        <div class="stat-num display"><span data-counter="4" data-suffix="" data-decimals="0">0</span></div>
        <div class="stat-label mono">Artists<br>on the roster</div>
      </div>
      <div class="stat" data-reveal>
        <div class="stat-num display"><span data-counter="9" data-suffix="" data-decimals="0">0</span><span class="stat-plus">+</span></div>
        <div class="stat-label mono">Countries fueling<br>the trend abroad</div>
      </div>
    </div>
  </section>

  <!-- MANIFEST (Mattman) -->
  <section class="mattman" id="manifest" data-bg="dark">
    <div class="container">
      <h2 class="mattman-statement display" data-blur-text>
        <span class="bt-word">Un</span>
        <span class="bt-word">label</span>
        <span class="bt-word">independent</span>
        <span class="bt-word">dedicat</span>
        <span class="bt-word">explorării</span>
        <span class="bt-word"><em>noilor</em></span>
        <span class="bt-word"><em>frontiere</em></span>
        <span class="bt-word"><em>sonore.</em></span>
      </h2>

      <div class="mattman-grid">
        <div class="mattman-col" data-reveal>
          <span class="mono gold">Manifest</span>
          <p>
            Combinăm <em>creativitatea brută</em> cu tehnologia de ultimă oră pentru a oferi artiștilor o platformă unde <span class="gold">autenticitatea este singura regulă</span>.
          </p>
          <p>
            De la producție meticuloasă la promovare strategică, transformăm ideile în experiențe audio memorabile.
          </p>
        </div>

        <div class="mattman-col" data-reveal>
          <span class="mono gold">Crez</span>
          <ul class="mattman-list">
            <li><span class="mono">01</span> Authenticity over algorithm.</li>
            <li><span class="mono">02</span> Sound first, image second.</li>
            <li><span class="mono">03</span> Independent. Always.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ROSTER (4 artists, 2x2) -->
  <section class="roster" id="roster">
    <div class="container">
      <div class="section-head">
        <span class="mono gold">[ 02 / Roster ]</span>
        <h2 class="section-title display" data-reveal>
          Four voices.<br><em class="grad-text">One sound.</em>
        </h2>
      </div>

      <div class="roster-grid" data-roster-grid>
        {roster.map((r, i) => (
          <article class={`roster-card hover-target r-${r.slug}`} data-slug={r.slug}>
            <button class="roster-card-trigger" type="button" data-roster-trigger={r.slug} aria-label={`Open ${r.name}`}></button>
            <header class="roster-card-head">
              <span class="roster-num mono">{String(i + 1).padStart(2, '0')}</span>
              {r.tag && <span class="roster-tag mono">{r.tag}</span>}
            </header>
            <div class="roster-photo">
              <img src={r.photo} alt={r.name} loading="lazy" />
              <img class="roster-photo-alt" src={r.photoAlt} alt="" loading="lazy" />
            </div>
            <div class="roster-info">
              <h3 class="roster-name display">{r.name}</h3>
              <p class="roster-tagline mono gold">{r.tagline}</p>
              <p class="roster-bio">{r.bio}</p>
            </div>

            <div class="roster-expanded" aria-hidden="true">
              <button class="roster-close" type="button" data-roster-close aria-label="Close">
                <span aria-hidden="true">×</span>
              </button>

              <header class="rx-header">
                <span class="rx-num mono">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="rx-name display">{r.name}</h3>
                <p class="rx-tagline mono gold">{r.tagline}</p>
              </header>

              <div class="rx-scroll">
                <div class="rx-block rx-bio">
                  <span class="mono gold rx-label">Bio</span>
                  <p>{r.bio}</p>
                </div>

                {r.media && r.media.length > 0 && (
                  <div class="rx-block rx-media">
                    <span class="mono gold rx-label">Media</span>
                    <div class="rx-media-grid">
                      {r.media.map((m) => (
                        <div class={`rx-media-item rx-media-${m.type}`}>
                          {m.type === 'youtube' && m.id ? (
                            <iframe
                              src={`https://www.youtube-nocookie.com/embed/${m.id}`}
                              title={m.title}
                              loading="lazy"
                              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                              allowfullscreen
                            ></iframe>
                          ) : m.type === 'spotify' && m.id ? (
                            <iframe
                              src={`https://open.spotify.com/embed/${m.kind || 'track'}/${m.id}`}
                              title={m.title}
                              loading="lazy"
                              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                            ></iframe>
                          ) : (
                            <div class="rx-media-empty mono">{m.title} — TBA</div>
                          )}
                          <span class="rx-media-title mono">{m.title}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {r.downloads && r.downloads.length > 0 && (
                  <div class="rx-block rx-downloads">
                    <span class="mono gold rx-label">Press Kit</span>
                    <ul class="rx-download-list">
                      {r.downloads.map((d) => (
                        <li>
                          <a class="rx-download mono hover-target" href={d.href} download>
                            <span>{d.label}</span>
                            <span class="rx-arrow">↓</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>

              <ul class="rx-socials mono">
                {r.socials.instagram && <li><a href={r.socials.instagram} target="_blank" rel="noopener" class="hover-target">Instagram ↗</a></li>}
                {r.socials.youtube && <li><a href={r.socials.youtube} target="_blank" rel="noopener" class="hover-target">YouTube ↗</a></li>}
                {r.socials.spotify && <li><a href={r.socials.spotify} target="_blank" rel="noopener" class="hover-target">Spotify ↗</a></li>}
                {r.socials.tiktok && <li><a href={r.socials.tiktok} target="_blank" rel="noopener" class="hover-target">TikTok ↗</a></li>}
              </ul>
            </div>
          </article>
        ))}

        <a class="roster-card roster-card-mini roster-card-shop hover-target" href="#" aria-disabled="true" data-shop>
          <header class="roster-card-head">
            <span class="roster-num mono">05</span>
            <span class="roster-tag mono">Shop</span>
          </header>
          <div class="mini-body">
            <h3 class="mini-title display"><em>Coming<br/>Soon.</em></h3>
          </div>
        </a>

        <a class="roster-card roster-card-mini roster-card-demos hover-target" href="mailto:demo@mattmanmusic.com">
          <header class="roster-card-head">
            <span class="roster-num mono">06</span>
            <span class="roster-tag mono">Demos</span>
          </header>
          <div class="mini-body">
            <h3 class="mini-title display">Send<br/><em>Demos.</em></h3>
          </div>
        </a>
      </div>

      <div class="roster-backdrop" data-roster-backdrop aria-hidden="true"></div>
    </div>
  </section>

  <!-- CATALOG (label flagship hits) -->
  <section class="discography" id="catalog" data-bg="light-end">
    <div class="container">
      <div class="section-head">
        <span class="mono">[ 03 / Catalog ]</span>
        <h2 class="section-title display" data-reveal>
          Two decades<br>of <em>noise</em>.
        </h2>
        <p class="section-sub mono">Featured releases from the label's catalog.</p>
      </div>

      <ol class="track-list">
        {tracks.map((t) => (
          <li class={`track ${t.highlight ? 'is-highlight' : ''}`} data-scramble-trigger>
            <span class="track-year mono">{t.year}</span>
            <span class="track-title display">
              <span data-decrypt>{t.title}</span>
              {t.highlight && <span class="track-star">★</span>}
            </span>
            <span class="track-feat mono">{t.feat || ''}</span>
            <span class="track-note mono">{t.note || ''}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- BOOKING -->
  <section class="booking" id="booking">
    <div class="container">
      <span class="mono">[ 04 / Booking ]</span>
      <h2 class="booking-title display" data-reveal-lines>
        <span class="reveal-line"><span>Let's make</span></span>
        <span class="reveal-line"><span>some <em class="grad-text">noise.</em></span></span>
      </h2>

      <div class="booking-grid">
        <div class="booking-col">
          <span class="mono">Booking &amp; Management</span>
          <a class="booking-mail display hover-target" href="mailto:booking@mattmanmusic.com">
            booking@mattmanmusic.com
          </a>
        </div>
        <div class="booking-col">
          <span class="mono">Press &amp; Label</span>
          <a class="booking-mail display hover-target" href="mailto:hello@mattmanmusic.com">
            hello@mattmanmusic.com
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="mono">© {new Date().getFullYear()} Mattman Music · All rights reserved</span>
      </div>
      <ul class="footer-social mono">
        <li><a href="https://youtube.com/@mattmanmusic" target="_blank" rel="noopener" class="hover-target">YouTube ↗</a></li>
      </ul>
      <div class="footer-credit mono">
        <span>Site by <a href="https://grappes.ai" target="_blank" rel="noopener" class="hover-target">Grappes</a></span>
      </div>
    </div>

  </footer>
</Layout>

<style>
  /* NAV */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: grid; grid-template-columns: 1fr auto;
    align-items: center; gap: 2rem;
    padding: 1.4rem var(--pad-x);
    pointer-events: none;
  }
  .nav > * { pointer-events: auto; }
  .nav-logo { order: 2; justify-self: end; }
  .nav-logo img { height: 32px; width: auto; transition: filter 0.6s ease; }
  body.dark .nav-logo img { filter: invert(1); }
  .nav-links {
    order: 1;
    display: flex; gap: 1.6rem;
    justify-self: center;
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    backdrop-filter: blur(10px);
    padding: 0.7rem 1.4rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
  }
  .nav-links a { transition: opacity 0.3s; }
  .nav-links a:hover { opacity: 0.5; }
  .nav-meta { opacity: 0.6; }

  @media (max-width: 820px) {
    .nav-links { display: none; }
    .nav { grid-template-columns: 1fr; }
    .nav-logo { justify-self: end; }
  }

  /* === HERO — sonic-echo editorial composition === */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: clamp(4.5rem, 9vh, 8rem) clamp(1.5rem, 4vh, 3rem);
  }
  .hero-sonic {
    position: relative;
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    display: grid;
    grid-template-areas:
      "stage"
      "sub"
      "br";
    grid-template-columns: 1fr;
    grid-template-rows: 1fr auto auto;
    gap: clamp(0.9rem, 2.2vw, 2.4rem) 1rem;
    align-items: center;
    min-height: clamp(420px, 72svh, 900px);
  }

  /* Corner labels */
  .hero-corner {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6em;
    font-size: clamp(0.62rem, 0.78vw, 0.72rem);
    letter-spacing: 0.18em;
    opacity: 0.7;
    line-height: 1;
    flex-wrap: wrap;
  }
  .hero-corner-num { color: var(--gold); }
  .hero-corner-dot { color: var(--gold); opacity: 0.8; }
  .hero-corner-br { grid-area: br; justify-self: center; text-align: center; }
  .hero-corner-arrow { display: inline-block; animation: bob 1.8s ease-in-out infinite; }

  /* Echo stack — main word + 4 fading echoes */
  .hero-echo-wrap {
    grid-area: stage;
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
    padding-block: clamp(1.5rem, 4vw, 4rem);
  }
  .hero-main,
  .hero-echo {
    font-family: 'Unbounded', 'Inter', sans-serif;
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -0.035em;
    text-transform: uppercase;
    margin: 0;
    width: 100%;
    text-align: center;
    white-space: nowrap;
    font-size: 18rem;
    font-variation-settings: 'wght' 900;
  }
  .hero-echo-wrap {
    /* enable JS-driven fit-to-width */
    container-type: inline-size;
  }
  .hero-main {
    position: relative;
    z-index: 5;
    color: var(--ink);
    display: flex;
    justify-content: center;
    gap: 0;
  }
  .hm-mask {
    display: inline-block;
    overflow: hidden;
    line-height: 0.95;
    padding-bottom: 0.05em;
  }
  .hm-char {
    display: inline-block;
    transform: translateY(110%);
    will-change: transform, font-variation-settings;
    font-variation-settings: 'wght' 250;
    transition: none;
  }
  .hero-main.is-loaded .hm-char,
  [data-hero-mark].is-loaded .hm-char { transform: translateY(0); }

  /* Echoes — concentric ripples behind the main word */
  .hero-echo {
    position: absolute;
    left: 0; right: 0;
    color: transparent;
    -webkit-text-stroke: 1px color-mix(in srgb, var(--fg) 60%, transparent);
    pointer-events: none;
    will-change: transform, opacity;
  }
  .hero-echo-1 { z-index: 4; opacity: 0; transform: scale(1.05); }
  .hero-echo-2 { z-index: 3; opacity: 0; transform: scale(1.12); }
  .hero-echo-3 { z-index: 2; opacity: 0; transform: scale(1.20); }
  .hero-echo-4 { z-index: 1; opacity: 0; transform: scale(1.30); }
  body.dark .hero-echo {
    -webkit-text-stroke-color: color-mix(in srgb, var(--cream) 60%, transparent);
  }

  /* Sub-line: rule — italic music — mono est. 2006 — rule */
  .hero-sub {
    grid-area: sub;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: clamp(1rem, 2vw, 2rem);
    width: 100%;
  }
  .hero-sub-rule {
    height: 1px;
    background: currentColor;
    opacity: 0.35;
    transform: scaleX(0);
    transform-origin: 50% 50%;
    transition: transform 1.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero-sub-rule:first-child { transform-origin: 100% 50%; }
  .hero-sub-rule:last-child { transform-origin: 0% 50%; }
  .hero-sonic[data-loaded] .hero-sub-rule { transform: scaleX(1); }
  .hero-sub-text {
    display: inline-flex; align-items: baseline; gap: 0.7em;
    font-family: 'Fraunces', serif;
    font-size: clamp(1rem, 1.4vw, 1.4rem);
    line-height: 1;
  }
  .hero-sub-italic {
    font-style: italic;
    color: var(--burgundy);
    font-size: 1.1em;
  }
  .hero-sub-mono {
    font-size: 0.55em;
    letter-spacing: 0.22em;
    opacity: 0.7;
  }
  body.dark .hero-sub-italic { color: var(--gold); }

  /* Mobile */
  @media (max-width: 720px) {
    .hero-sonic { gap: 0.8rem; min-height: 70svh; }
    .hero-sub { gap: 0.7rem; }
    .hero-sub-text { font-size: 0.82rem; gap: 0.5em; }
    .hero-echo-3, .hero-echo-4 { display: none; }
  }
  @media (max-width: 380px) {
    .hero-sub-text { font-size: 0.74rem; }
    .hero-corner-br { font-size: 0.55rem; }
  }
  .hero-arrow {
    display: inline-block;
    animation: bob 1.8s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* SECTION SCAFFOLD */
  .section-head {
    display: flex; flex-direction: column; gap: 1rem;
    margin-bottom: clamp(3rem, 6vw, 6rem);
  }
  .section-title {
    font-size: clamp(2.2rem, 8.5vw, 9rem);
    line-height: 0.86;
  }
  .section-title em { font-style: italic; color: var(--burgundy); }
  body.dark .section-title em { color: var(--gold); }
  .section-sub { opacity: 0.6; max-width: 50ch; margin-top: 1rem; }
  .hero-roster-mini {
    display: flex; gap: 0.5rem; flex-wrap: wrap;
    align-items: center; opacity: 0.65;
    font-size: 0.7rem;
  }
  .hero-roster-mini .hero-roster-dot { color: var(--gold); }

  /* ABOUT */
  .about {
    padding-block: var(--pad-y);
    border-top: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(2rem, 6vw, 6rem);
  }
  .about-side { position: sticky; top: 6rem; align-self: start; display: flex; flex-direction: column; gap: 1rem; }
  .about-side-title {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 0.86;
  }
  .about-body {
    display: flex; flex-direction: column; gap: 1.6rem;
    font-size: clamp(1.05rem, 1.2vw, 1.25rem);
    line-height: 1.55;
    max-width: 56ch;
  }
  .about-body em { font-style: italic; }
  .about-body strong { font-weight: 500; }
  .about-lead { font-size: clamp(1.4rem, 2vw, 2rem); line-height: 1.35; font-family: var(--font-display); font-weight: 400; }
  .about-lead em { font-style: italic; color: var(--burgundy); }
  .gold { color: var(--gold); }

  @media (max-width: 820px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-side { position: static; }
  }

  /* DISCOGRAPHY */
  .discography {
    padding-block: var(--pad-y);
    border-top: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
  }
  .track-list { display: flex; flex-direction: column; }
  .track {
    display: grid;
    grid-template-columns: 5rem 1fr auto auto;
    align-items: baseline;
    gap: 1.2rem;
    padding-block: 1.4rem;
    border-top: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
    transition: padding 0.4s ease, color 0.4s ease;
  }
  .track:last-child { border-bottom: 1px solid color-mix(in srgb, var(--fg) 12%, transparent); }
  .track:hover { padding-inline-start: 1.4rem; color: var(--burgundy); }
  .track-year { opacity: 0.5; }
  .track-title {
    font-size: clamp(1.4rem, 3.2vw, 3rem);
    line-height: 1;
    display: inline-flex; align-items: baseline; gap: 0.4em;
    min-width: 0;
  }
  .track-star { color: var(--gold); font-size: 0.6em; }
  .track-feat { opacity: 0.7; white-space: nowrap; }
  .track-note { opacity: 0.6; text-align: right; white-space: nowrap; }
  .track.is-highlight .track-title { font-style: italic; }
  .track.is-highlight .track-note { color: var(--gold); opacity: 1; }

  @media (max-width: 820px) {
    .track { grid-template-columns: auto 1fr; gap: 0.4rem 0.9rem; padding-block: 1rem; }
    .track-feat, .track-note { grid-column: 2; text-align: left; white-space: normal; font-size: 0.62rem; }
  }
  @media (max-width: 480px) {
    .track-title { font-size: clamp(1.05rem, 6vw, 1.6rem); }
    .track-year { font-size: 0.62rem; }
  }

  /* MATTMAN */
  .mattman {
    padding-block: var(--pad-y);
    border-top: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
  }
  .mattman-head { margin-bottom: 4rem; }
  .mattman-stage {
    display: flex; justify-content: center;
    padding-block: 3rem;
  }
  .mattman-logo {
    width: clamp(240px, 50vw, 600px);
    height: auto;
    will-change: transform;
  }
  .mattman-statement {
    font-size: clamp(1.9rem, 6vw, 7rem);
    text-align: center;
    margin-block: clamp(2rem, 6vw, 4rem) clamp(2.5rem, 8vw, 6rem);
    line-height: 1;
  }
  .mattman-statement em { font-style: italic; color: var(--gold); }
  .mattman-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 6rem);
    max-width: 1200px;
    margin-inline: auto;
  }
  .mattman-col {
    display: flex; flex-direction: column; gap: 1.4rem;
    font-size: 1.05rem; line-height: 1.6;
  }
  .mattman-col em { font-style: italic; }
  .mattman-list { display: flex; flex-direction: column; gap: 1rem; }
  .mattman-list li {
    display: flex; gap: 1.5rem;
    padding-block: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--fg) 18%, transparent);
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.2vw, 2rem);
  }
  .mattman-list li .mono { color: var(--gold); align-self: center; min-width: 2.5rem; }
  @media (max-width: 820px) {
    .mattman-grid { grid-template-columns: 1fr; }
  }

  /* ROSTER */
  .roster {
    padding-block: var(--pad-y);
    border-top: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
  }
  /* 2x2 always — never stacks regardless of screen */
  .roster-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 2.5rem) clamp(1rem, 2vw, 2.5rem);
  }
  .roster-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    border: 1px solid color-mix(in srgb, var(--fg) 16%, transparent);
    background: color-mix(in srgb, var(--bg) 96%, var(--fg) 4%);
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.4s ease;
  }
  .roster-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--fg) 40%, transparent);
  }
  .roster-card-head {
    position: absolute; top: clamp(0.7rem, 1.2vw, 1.2rem); left: clamp(0.7rem, 1.2vw, 1.2rem); right: clamp(0.7rem, 1.2vw, 1.2rem);
    z-index: 3;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 0.7rem;
    pointer-events: none;
    mix-blend-mode: difference;
    color: #fff;
  }
  .roster-num { color: var(--gold); letter-spacing: 0.18em; }
  .roster-tag {
    color: var(--gold);
    border: 1px solid color-mix(in srgb, var(--gold) 60%, transparent);
    padding: 0.25em 0.7em;
    border-radius: 999px;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    background: color-mix(in srgb, var(--ink) 30%, transparent);
    backdrop-filter: blur(4px);
  }
  .roster-photo {
    position: absolute; inset: 0;
    overflow: hidden;
    background: var(--ink-soft);
  }
  .roster-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.2, 0.8, 0.2, 1), filter 0.8s ease, opacity 0.6s ease;
    filter: grayscale(0.4) contrast(1.05);
  }
  .roster-photo .roster-photo-alt {
    position: absolute; inset: 0;
    opacity: 0;
  }
  .roster-card:hover .roster-photo img { transform: scale(1.04); filter: grayscale(0) contrast(1.1); }
  .roster-card:hover .roster-photo-alt { opacity: 1; }

  /* Default-state info (name/tagline/bio) hidden — only the photo shows in the card.
     Info appears in the expanded panel via .rx-header + .rx-bio. */
  .roster-info { display: none; }
  @media (max-width: 720px) {
    .roster-grid { gap: 0.7rem; }
    .roster-card { padding: 0.7rem; gap: 0.65rem; }
  }
  @media (max-width: 480px) {
    .roster-grid { gap: 0.5rem; }
    .roster-card { padding: 0.5rem; gap: 0.45rem; }
    .roster-name { font-size: clamp(0.95rem, 5vw, 1.4rem); line-height: 1; }
    .roster-bio { font-size: 0.66rem; line-height: 1.4; }
    .roster-tagline { font-size: 0.5rem; letter-spacing: 0.1em; }
    .roster-tag { padding: 0.18em 0.45em; font-size: 0.45rem; letter-spacing: 0.1em; }
    .roster-num { font-size: 0.5rem; letter-spacing: 0.1em; }
    .roster-card-head { font-size: 0.55rem; }
  }

  /* === ROSTER CARD: invisible click trigger === */
  .roster-card { cursor: pointer; }
  .roster-card-trigger {
    position: absolute; inset: 0;
    background: none; border: 0; padding: 0; margin: 0;
    cursor: pointer; z-index: 4;
  }
  .roster-card-trigger:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: -4px;
  }

  /* === MINI TILES (Shop / Send Demos) — side by side under the 2x2 roster === */
  .roster-card-mini {
    aspect-ratio: auto;
    flex-direction: column !important;
    justify-content: center;
    align-items: stretch;
    min-height: clamp(140px, 18vw, 220px);
    padding: clamp(1rem, 2vw, 2rem) !important;
    text-decoration: none;
    color: inherit;
    background: color-mix(in srgb, var(--bg) 96%, var(--fg) 4%);
    position: relative;
    overflow: hidden;
    transition: border-color 0.4s ease, transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .roster-card-mini:hover { transform: translateY(-3px); }

  .roster-card-shop {
    cursor: not-allowed;
    background:
      linear-gradient(135deg,
        color-mix(in srgb, var(--bg) 96%, var(--fg) 4%) 0%,
        color-mix(in srgb, var(--bg) 92%, var(--gold) 8%) 100%);
  }
  .roster-card-shop::after {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent 0 18px,
      color-mix(in srgb, var(--gold) 6%, transparent) 18px 19px
    );
    pointer-events: none;
    opacity: 0.4;
  }

  .roster-card-demos {
    background:
      linear-gradient(135deg,
        color-mix(in srgb, var(--bg) 96%, var(--fg) 4%) 0%,
        color-mix(in srgb, var(--bg) 88%, var(--burgundy) 12%) 100%);
  }
  body.dark .roster-card-demos {
    background:
      linear-gradient(135deg,
        color-mix(in srgb, var(--bg) 96%, var(--fg) 4%) 0%,
        color-mix(in srgb, var(--bg) 88%, var(--gold) 12%) 100%);
  }
  .roster-card-demos:hover {
    border-color: color-mix(in srgb, var(--gold) 60%, transparent);
  }

  .roster-card-mini .roster-card-head {
    position: absolute; top: clamp(0.7rem, 1.4vw, 1.4rem); left: clamp(0.7rem, 1.4vw, 1.4rem); right: clamp(0.7rem, 1.4vw, 1.4rem);
    z-index: 2;
    mix-blend-mode: normal;
    color: inherit;
  }
  .mini-body {
    z-index: 2; position: relative;
    width: 100%;
    text-align: left;
    padding: clamp(3rem, 5vw, 4.5rem) 0 clamp(0.6rem, 1vw, 1rem);
  }
  .mini-title {
    font-size: clamp(2.4rem, 6.5vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .mini-title em { font-style: italic; color: var(--burgundy); }
  body.dark .mini-title em { color: var(--gold); }
  .roster-card-mini { min-height: clamp(220px, 28vw, 360px); }

  /* === INLINE EXPANDED CARD === */
  .roster-grid { position: relative; }
  .roster-backdrop { display: none; }

  /* Per-card view-transition-name so the browser morphs each independently */
  .roster-card.r-matteo { view-transition-name: rc-matteo; }
  .roster-card.r-andrei { view-transition-name: rc-andrei; }
  .roster-card.r-georgiana { view-transition-name: rc-georgiana; }
  .roster-card.r-emily { view-transition-name: rc-emily; }
  ::view-transition-old(*),
  ::view-transition-new(*) {
    animation-duration: 0.55s;
    animation-timing-function: cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Active card grows: spans full grid width, taller, photo to one side and EPK content the other */
  .roster-grid.is-open .roster-card.is-active {
    grid-column: 1 / -1;
    aspect-ratio: auto;
    min-height: clamp(520px, 78vh, 820px);
  }

  /* Photo: when active, shrinks to left half of the expanded card */
  .roster-card.is-active .roster-photo {
    inset: 0 auto 0 0;
    width: clamp(38%, 42%, 50%);
  }
  .roster-card.is-active .roster-photo img {
    filter: grayscale(0) contrast(1.05);
  }

  /* Expanded panel (EPK content) sits inside the card on the right half */
  .roster-card .roster-expanded {
    position: absolute;
    top: 0; bottom: 0; right: 0;
    left: clamp(38%, 42%, 50%);
    background: var(--bg);
    border-left: 1px solid color-mix(in srgb, var(--fg) 14%, transparent);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.45s ease 0.05s;
    padding: clamp(1.2rem, 2.2vw, 2.4rem);
    overflow: hidden;
  }
  body.dark .roster-card .roster-expanded {
    background: var(--ink);
    border-left-color: color-mix(in srgb, var(--cream) 14%, transparent);
  }
  .roster-card.is-active .roster-expanded {
    opacity: 1;
    pointer-events: auto;
  }
  .roster-card.is-active .roster-card-trigger { pointer-events: none; }
  /* Hide the corner num/tag on active card to avoid overlapping the EPK header */
  .roster-card.is-active .roster-card-head { opacity: 0; }

  /* Other cards stay normal — no dimming when one is open (per inline-expand pattern) */

  .roster-close {
    position: absolute; top: clamp(0.8rem, 1.5vw, 1.5rem); right: clamp(0.8rem, 1.5vw, 1.5rem);
    width: clamp(2.4rem, 3vw, 3rem); height: clamp(2.4rem, 3vw, 3rem);
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--fg) 30%, transparent);
    background: transparent;
    color: inherit;
    font-size: 1.5rem; line-height: 1;
    cursor: pointer; z-index: 70;
    display: grid; place-items: center;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }
  .roster-close:hover {
    background: color-mix(in srgb, var(--fg) 8%, transparent);
    transform: rotate(90deg);
  }

  .rx-header {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 1.2rem;
    row-gap: 0.4rem;
    align-items: baseline;
    padding-right: clamp(3rem, 5vw, 5rem);
    margin-bottom: clamp(1.2rem, 2.4vw, 2.4rem);
    border-bottom: 1px solid color-mix(in srgb, var(--fg) 14%, transparent);
    padding-bottom: clamp(1rem, 2vw, 1.6rem);
  }
  .rx-num {
    grid-row: 1 / span 2;
    color: var(--gold);
    letter-spacing: 0.2em;
    font-size: 0.7rem;
    align-self: start;
    padding-top: 0.6rem;
  }
  .rx-name {
    font-size: clamp(2rem, 4.5vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
  }
  .rx-tagline {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
  }

  .rx-scroll {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    display: flex;
    flex-direction: column;
    gap: clamp(1.2rem, 2vw, 1.8rem);
    padding-right: clamp(0.4rem, 0.8vw, 0.8rem);
    padding-bottom: clamp(2rem, 4vh, 3rem);
  }
  .rx-block { display: flex; flex-direction: column; gap: 0.7rem; }
  .rx-label {
    font-size: 0.6rem; letter-spacing: 0.2em;
  }
  .rx-bio p {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.1vw, 1.15rem);
    line-height: 1.5;
  }
  .rx-bio p em { font-style: italic; }
  .rx-media-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.7rem;
  }
  .rx-media-item {
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .rx-media-item iframe,
  .rx-media-empty {
    width: 100%;
    aspect-ratio: 16/9;
    border: 0;
    background: color-mix(in srgb, var(--fg) 8%, transparent);
    display: grid; place-items: center;
    color: inherit; opacity: 0.6;
    font-size: 0.7rem; letter-spacing: 0.18em;
  }
  .rx-media-spotify iframe { aspect-ratio: 16/5; }
  .rx-media-title {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    opacity: 0.6;
  }
  .rx-download-list {
    display: flex; flex-direction: column;
    border-top: 1px solid color-mix(in srgb, var(--fg) 18%, transparent);
  }
  .rx-download {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--fg) 18%, transparent);
    font-size: 0.7rem; letter-spacing: 0.16em;
    transition: padding 0.4s, color 0.4s;
  }
  .rx-download:hover { padding-inline-start: 0.6rem; color: var(--gold); }
  .rx-arrow { opacity: 0.6; }

  .rx-socials {
    border-top: 1px solid color-mix(in srgb, var(--fg) 18%, transparent);
    padding-top: clamp(0.8rem, 1.4vw, 1.2rem);
    margin-top: auto;
    display: flex; flex-wrap: wrap;
    gap: clamp(1rem, 2vw, 2rem);
    font-size: 0.7rem; letter-spacing: 0.16em;
    flex-shrink: 0;
  }
  .rx-socials a { transition: opacity 0.3s; }
  .rx-socials a:hover { opacity: 0.55; }

  /* Mobile: active card stacks vertically — photo on top, EPK below */
  @media (max-width: 820px) {
    .roster-grid.is-open .roster-card.is-active {
      min-height: clamp(560px, 92vh, 900px);
    }
    .roster-card.is-active .roster-photo {
      inset: 0 0 auto 0;
      width: auto;
      height: 38%;
    }
    .roster-card .roster-expanded {
      top: 38%;
      left: 0;
      border-left: 0;
      border-top: 1px solid color-mix(in srgb, var(--fg) 14%, transparent);
      padding: 1rem 1rem 1.2rem;
    }
    body.dark .roster-card .roster-expanded {
      border-top-color: color-mix(in srgb, var(--cream) 14%, transparent);
    }
    .rx-media-grid { grid-template-columns: 1fr; }
    .roster-card-shop {
      flex-direction: column !important;
      min-height: 110px;
    }
  }

  /* BOOKING */
  .booking {
    padding-block: var(--pad-y);
    border-top: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
  }
  .booking-title {
    font-size: clamp(2.6rem, 11vw, 12rem);
    line-height: 0.85;
    margin-block: 1.5rem 3rem;
  }
  .booking-title em { font-style: italic; color: var(--burgundy); }
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    margin-bottom: 4rem;
  }
  .booking-col { display: flex; flex-direction: column; gap: 0.6rem; }
  .booking-mail {
    font-size: clamp(0.95rem, 2.5vw, 2.4rem);
    line-height: 1.15;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.2em;
    align-self: flex-start;
    transition: color 0.4s, padding 0.4s;
    word-break: break-all;
    max-width: 100%;
  }
  .booking-mail:hover { color: var(--burgundy); padding-left: 0.4em; }
  .booking-cta { margin-top: 2rem; }
  @media (max-width: 720px) {
    .booking-grid { grid-template-columns: 1fr; }
  }

  /* FOOTER */
  .footer {
    padding: 3rem var(--pad-x) 0;
    border-top: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
    overflow: hidden;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    align-items: end;
    padding-bottom: 3rem;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 1rem; }
  .footer-brand img { height: 36px; width: auto; }
  .footer-social { display: flex; gap: 1.4rem; justify-content: center; flex-wrap: wrap; }
  .footer-social a { transition: opacity 0.3s; }
  .footer-social a:hover { opacity: 0.5; }
  .footer-credit { text-align: right; opacity: 0.6; }
  .footer-credit a { border-bottom: 1px solid currentColor; }

  .footer-mega {
    font-size: clamp(8rem, 30vw, 28rem);
    line-height: 0.85;
    text-align: center;
    margin-bottom: -0.18em;
    letter-spacing: -0.06em;
    opacity: 0.92;
  }

  @media (max-width: 820px) {
    .footer { padding-inline: clamp(1.4rem, 6vw, 3rem); }
    .footer-inner { grid-template-columns: 1fr; gap: 2rem; padding-left: 0.6rem; }
    .footer-brand,
    .footer-social,
    .footer-credit { text-align: left; }
    .footer-social { justify-content: flex-start; }
  }
</style>

<script>
  // === ROSTER expand / close ===
  const grid = document.querySelector('[data-roster-grid]');
  const cards = document.querySelectorAll<HTMLElement>('.roster-card[data-slug]');
  const triggers = document.querySelectorAll<HTMLElement>('[data-roster-trigger]');
  const closeBtns = document.querySelectorAll<HTMLElement>('[data-roster-close]');
  const backdrop = document.querySelector<HTMLElement>('[data-roster-backdrop]');
  const shopTile = document.querySelector<HTMLElement>('[data-shop]');

  let activeSlug: string | null = null;

  const applyOpen = (slug: string) => {
    if (!grid) return;
    grid.classList.add('is-open');
    grid.setAttribute('data-active', slug);
    cards.forEach((c) => {
      const isMatch = c.getAttribute('data-slug') === slug;
      c.classList.toggle('is-active', isMatch);
      const expanded = c.querySelector('.roster-expanded');
      if (expanded) expanded.setAttribute('aria-hidden', isMatch ? 'false' : 'true');
    });
  };

  const applyClose = () => {
    if (!grid) return;
    grid.classList.remove('is-open');
    grid.removeAttribute('data-active');
    cards.forEach((c) => {
      c.classList.remove('is-active');
      const expanded = c.querySelector('.roster-expanded');
      if (expanded) expanded.setAttribute('aria-hidden', 'true');
    });
  };

  const morph = (fn: () => void) => {
    // @ts-ignore — View Transitions API
    if (typeof document.startViewTransition === 'function') {
      // @ts-ignore
      document.startViewTransition(fn);
    } else {
      fn();
    }
  };

  const openCard = (slug: string) => {
    activeSlug = slug;
    morph(() => applyOpen(slug));
    // smooth scroll the active card into view a moment after the morph
    requestAnimationFrame(() => {
      const card = document.querySelector(`.roster-card[data-slug="${slug}"]`);
      if (card) {
        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  };

  const closeCard = () => {
    activeSlug = null;
    morph(() => applyClose());
  };

  triggers.forEach((t) => {
    t.addEventListener('click', (e) => {
      e.preventDefault();
      const slug = t.getAttribute('data-roster-trigger');
      if (slug) openCard(slug);
    });
  });

  closeBtns.forEach((b) => {
    b.addEventListener('click', (e) => {
      e.stopPropagation();
      closeCard();
    });
  });

  if (backdrop) {
    backdrop.addEventListener('click', closeCard);
  }

  // Click outside any active panel = close (when click target is one of the dim non-active cards)
  cards.forEach((c) => {
    c.addEventListener('click', (e) => {
      if (!activeSlug) return;
      if (c.classList.contains('is-active')) return;
      // dim card click closes
      const target = e.target as HTMLElement;
      if (target.closest('[data-roster-trigger]')) return; // let triggers handle
      closeCard();
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && activeSlug) closeCard();
  });

  if (shopTile) {
    shopTile.addEventListener('click', (e) => e.preventDefault());
  }
</script>
