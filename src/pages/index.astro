---
import Layout from '../layouts/Layout.astro';

const tracks = [
  { year: '2006', title: 'Departare', feat: 'feat. Loredana', note: 'Debut' },
  { year: '2010', title: 'Lovaman', feat: 'EP', note: 'First EP' },
  { year: '2012', title: 'Push It', feat: 'feat. Stella' },
  { year: '2013', title: 'Amândoi' },
  { year: '2013', title: 'Panama', note: '225M+ views', highlight: true },
  { year: '2014', title: 'Andale' },
  { year: '2015', title: 'Gândesc cu voce tare' },
  { year: '2017', title: 'Bună, Marie!', feat: 'feat. Uddi' },
  { year: '2018', title: 'Allegro Ventigo', feat: 'feat. Dan Bălan', highlight: true },
  { year: '2021', title: 'Copacul', feat: 'feat. Theo Rose' },
  { year: '2023', title: 'Lato Lato Song', feat: 'feat. Sean Al' },
  { year: '2025', title: 'Gypsy Reggae', feat: 'EP', note: 'New genre. New era.', highlight: true },
];

const roster = [
  {
    slug: 'matteo',
    name: 'Matteo',
    tag: 'Founder',
    tagline: 'Two decades. Hit after hit.',
    bio: 'Founder of Mattman Music. Almost two decades of hits — debut "Departare" (2006, with Loredana). Most viral single "Panama" — 225M+ views, going global on TikTok across Asia. Latest venture: a self-coined fusion genre, Gypsy Reggae, with King Kong, Anthony B, Loyal Flames and Johny Romano.',
    photo: '/images/matteo/portrait-md.jpg',
  },
  {
    slug: 'andrei',
    name: 'Andrei Bănuță',
    tagline: 'An artist of contrasts.',
    bio: 'One of the most in-demand voices today. Songwriting that alternates between deep, meaningful lyrics and vibrant, playful songs. Best known for "Suflet de Bagabond" (90M+ views) and "Old Friend" with Vescan — over 10 weeks atop the Media Forest Chart.',
    photo: '/images/roster/andrei.jpg',
  },
  {
    slug: 'georgiana',
    name: 'Georgiana Neagu',
    tagline: 'The new wave of balkan pop.',
    bio: 'A new wave of Romanian balkan pop. Contemporary sound and relatable lyrics that connect with a young audience nationwide. "M-am Îndrăgostit de Tine (Vreau să facem o fetiță)" — viral on TikTok, 2.2M+ views on YouTube.',
    photo: '/images/roster/georgiana.jpg',
  },
  {
    slug: 'emily',
    name: 'Emily Istrate',
    tagline: 'Beautiful, talented, charismatic.',
    bio: 'Singer, songwriter, actress from the Republic of Moldova. International recognition with "If You Want To" and "Panic" — UK Pop Club Charts #4 and #5. 2023 saw her climb the top of major Romanian charts with "Bye Bye Boy" and "În Mintea Mea".',
    photo: '/images/roster/emily.jpg',
  },
];
---
<Layout>
  <!-- NAV -->
  <nav class="nav">
    <a href="#top" class="nav-logo hover-target" data-magnetic="0.4">
      <img src="/images/mattman/logo-black.png" alt="Mattman Music" class="nav-logo-img" />
    </a>
    <ul class="nav-links mono">
      <li><a href="#manifest">Manifest</a></li>
      <li><a href="#roster">Roster</a></li>
      <li><a href="#catalog">Catalog</a></li>
      <li><a href="#correspondence">Correspondence</a></li>
    </ul>
  </nav>

  <!-- ============================== -->
  <!-- 01 — COVER (magazine front)    -->
  <!-- ============================== -->
  <section class="cover" id="top">
    <span class="folio cover-folio-tl">
      <span class="mono">Vol. 01</span>
      <span class="mono">№ MM — 2026</span>
    </span>
    <span class="folio cover-folio-tr">
      <span class="mono">Independent</span>
      <span class="mono">București · Worldwide</span>
    </span>

    <span class="cover-spine mono" aria-hidden="true">An Anthology of Independent Sound · Established Two-Thousand and Six · Vol. 01</span>

    <div class="cover-stage">
      <span class="cover-kicker mono">— A Mattman Music Edition —</span>
      <h1 class="cover-headline">
        <span class="ch-italic">Mattman</span><span class="ch-period">.</span>
      </h1>
      <p class="cover-deck">
        An independent <em>edition of sound,</em><br>
        pressed since <span class="cover-year">two-thousand and six</span>.
      </p>
      <span class="cover-rule" aria-hidden="true"></span>
      <p class="cover-byline mono">Featuring · Matteo · Andrei Bănuță · Georgiana Neagu · Emily Istrate</p>
    </div>

    <span class="folio cover-folio-bl">
      <span class="mono">Begin reading ↓</span>
    </span>
    <span class="folio cover-folio-br">
      <span class="mono">p. 01</span>
    </span>
  </section>

  <!-- ============================== -->
  <!-- 02 — MASTHEAD / NUMBERS         -->
  <!-- ============================== -->
  <section class="masthead">
    <div class="container masthead-grid">
      <div class="masthead-col masthead-intro">
        <span class="folio-mark mono">— 02 / By the Numbers</span>
        <p class="masthead-lead">
          A house of <em>hit-makers</em>, fluent in pop, balkan, reggae and the spaces between.
        </p>
      </div>

      <figure class="masthead-figure masthead-figure-hero" data-reveal>
        <span class="masthead-num display">225<span class="masthead-num-suffix">M+</span></span>
        <figcaption class="mono">Views on <em>Panama</em>, the label's most viral single.</figcaption>
      </figure>

      <figure class="masthead-figure" data-reveal>
        <span class="masthead-num-sm display">2<span class="masthead-num-suffix">+</span></span>
        <figcaption class="mono">Decades of releases</figcaption>
      </figure>

      <figure class="masthead-figure" data-reveal>
        <span class="masthead-num-sm display">4</span>
        <figcaption class="mono">Voices on the roster</figcaption>
      </figure>

      <figure class="masthead-figure" data-reveal>
        <span class="masthead-num-sm display">9<span class="masthead-num-suffix">+</span></span>
        <figcaption class="mono">Countries fueling the trend abroad</figcaption>
      </figure>
    </div>
  </section>

  <!-- ============================== -->
  <!-- 03 — MANIFEST (pull-quote)     -->
  <!-- ============================== -->
  <section class="manifesto" id="manifest" data-bg="dark">
    <div class="container manifesto-spread">
      <header class="manifesto-head">
        <span class="folio-mark mono">— 03 / Manifest</span>
        <span class="folio-mark mono">p. 03</span>
      </header>

      <blockquote class="manifesto-quote">
        <span class="quote-glyph" aria-hidden="true">“</span>
        <p data-blur-text>
          <span class="bt-word">Un</span>
          <span class="bt-word">label</span>
          <span class="bt-word">independent,</span>
          <span class="bt-word">dedicat</span>
          <span class="bt-word">explorării</span>
          <span class="bt-word"><em>noilor</em></span>
          <span class="bt-word"><em>frontiere</em></span>
          <span class="bt-word"><em>sonore.</em></span>
        </p>
        <span class="quote-glyph quote-glyph-end" aria-hidden="true">”</span>
      </blockquote>

      <div class="manifesto-columns">
        <div class="manifesto-body" data-reveal>
          <p class="has-dropcap"><span class="dropcap">C</span>ombinăm <em>creativitatea brută</em> cu tehnologia de ultimă oră pentru a oferi artiștilor o platformă unde <span class="gold">autenticitatea este singura regulă</span>.</p>
          <p>De la producție meticuloasă la promovare strategică, transformăm ideile în experiențe audio memorabile, presate la calitate de catalog.</p>
        </div>

        <aside class="manifesto-creed" data-reveal>
          <span class="mono gold">— Crez</span>
          <ol class="creed-list">
            <li>
              <span class="creed-num mono">i.</span>
              <span class="creed-text">Authenticity over algorithm.</span>
            </li>
            <li>
              <span class="creed-num mono">ii.</span>
              <span class="creed-text">Sound first, image second.</span>
            </li>
            <li>
              <span class="creed-num mono">iii.</span>
              <span class="creed-text">Independent. <em>Always.</em></span>
            </li>
          </ol>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- 04 — ROSTER (cinematic spreads)-->
  <!-- ============================== -->
  <section class="suite" id="roster">
    <header class="suite-head">
      <div class="container">
        <span class="folio-mark mono">— 04 / The Roster</span>
        <h2 class="suite-title display" data-reveal>
          Four voices,<br><em>one</em> label.
        </h2>
        <p class="suite-deck">A four-part feature on the artists carrying the catalog.</p>
      </div>
    </header>

    {roster.map((r, i) => (
      <article class={`spread spread-${r.slug}`} data-spread-index={i}>
        <span class="spread-spine mono" aria-hidden="true">{r.name} · Mattman Music · Vol. 01</span>

        <div class="spread-folio spread-folio-tl">
          <span class="mono">— Feature №&nbsp;{String(i + 1).padStart(2, '0')}</span>
        </div>
        <div class="spread-folio spread-folio-tr">
          <span class="mono">{r.tag ? r.tag : 'Artist'}</span>
        </div>

        <div class="spread-image-frame">
          <img src={r.photo} alt={r.name} loading="lazy" />
          <span class="spread-image-caption mono">Fig. {String(i + 1).padStart(2, '0')} — {r.name}</span>
        </div>

        <div class="spread-text">
          <span class="spread-eyebrow mono">{r.tagline}</span>
          <h3 class="spread-name">
            <span class="ch-italic">{r.name}</span><span class="ch-period">.</span>
          </h3>
          <p class="spread-bio has-dropcap"><span class="dropcap">{r.bio.charAt(0)}</span>{r.bio.slice(1)}</p>
        </div>

        <div class="spread-folio spread-folio-bl">
          <span class="mono">— continued —</span>
        </div>
        <div class="spread-folio spread-folio-br">
          <span class="mono">p. {String(i + 4).padStart(2, '0')}</span>
        </div>
      </article>
    ))}
  </section>

  <!-- ============================== -->
  <!-- 05 — CATALOG (editorial index) -->
  <!-- ============================== -->
  <section class="catalog" id="catalog" data-bg="light-end">
    <div class="container">
      <header class="catalog-head">
        <span class="folio-mark mono">— 05 / Selected Works</span>
        <h2 class="catalog-title display" data-reveal>
          A catalog<br>of <em>noise</em>.
        </h2>
        <p class="catalog-deck">Two decades, twelve singles. The label's enduring releases — listed in the order they were pressed.</p>
      </header>

      <ol class="entries">
        {tracks.map((t, i) => (
          <li class={`entry ${t.highlight ? 'is-highlight' : ''}`} data-scramble-trigger>
            <span class="entry-num mono">{String(i + 1).padStart(2, '0')}</span>
            <span class="entry-year mono">{t.year}</span>
            <span class="entry-title">
              <span data-decrypt>{t.title}</span>
              {t.highlight && <span class="entry-star">★</span>}
            </span>
            <span class="entry-feat mono">{t.feat || '—'}</span>
            <span class="entry-note mono">{t.note || ''}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================== -->
  <!-- 06 — CORRESPONDENCE             -->
  <!-- ============================== -->
  <section class="correspondence" id="correspondence">
    <div class="container correspondence-grid">
      <header class="correspondence-head">
        <span class="folio-mark mono">— 06 / Correspondence</span>
      </header>

      <div class="correspondence-letter">
        <p class="letter-open"><em>Dear reader,</em></p>
        <p class="letter-body">
          For booking, performances, press inquiries, or collaborations, address letters to —
        </p>

        <div class="letter-addresses">
          <a class="letter-mail hover-target" href="mailto:booking@mattmanmusic.com">
            <span class="letter-mail-label mono">Booking & Management</span>
            <span class="letter-mail-addr">booking@mattmanmusic.com</span>
          </a>
          <a class="letter-mail hover-target" href="mailto:hello@mattmanmusic.com">
            <span class="letter-mail-label mono">Press & Label</span>
            <span class="letter-mail-addr">hello@mattmanmusic.com</span>
          </a>
        </div>

        <p class="letter-sign">
          <em>Yours,</em><br>
          <span class="letter-signoff display">Mattman.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- COLOPHON                       -->
  <!-- ============================== -->
  <footer class="colophon">
    <div class="container colophon-inner">
      <span class="mono">Vol. 01 · {new Date().getFullYear()}</span>
      <span class="mono">© Mattman Music · All rights reserved</span>
      <a href="https://youtube.com/@mattmanmusic" target="_blank" rel="noopener" class="mono hover-target">YouTube ↗</a>
      <span class="mono">Site by <a href="https://grappes.ai" target="_blank" rel="noopener" class="hover-target">Grappes</a></span>
    </div>
  </footer>
</Layout>

<style>
  /* ============================== */
  /*  GLOBAL EDITORIAL UTILITIES    */
  /* ============================== */
  .folio-mark {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    opacity: 0.62;
  }
  .folio {
    position: absolute;
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 0.35em;
    font-size: clamp(0.6rem, 0.78vw, 0.72rem);
    letter-spacing: 0.22em;
    line-height: 1.2;
    opacity: 0.72;
    pointer-events: none;
  }
  .has-dropcap { text-indent: 0; }
  .dropcap {
    float: left;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 4.6em;
    line-height: 0.78;
    padding-right: 0.12em;
    padding-top: 0.08em;
    color: var(--burgundy);
  }
  body.dark .dropcap { color: var(--gold); }

  .ch-italic {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 400;
  }
  .ch-period {
    font-family: 'Fraunces', serif;
    color: var(--burgundy);
    font-style: normal;
  }
  body.dark .ch-period { color: var(--gold); }

  /* ============================== */
  /*  NAV                           */
  /* ============================== */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: grid; grid-template-columns: 1fr auto;
    align-items: center; gap: 2rem;
    padding: 1.4rem var(--pad-x);
    pointer-events: none;
  }
  .nav > * { pointer-events: auto; }
  .nav-logo { order: 2; justify-self: end; }
  .nav-logo img { height: 28px; width: auto; transition: filter 0.6s ease; }
  body.dark .nav-logo img { filter: invert(1); }
  .nav-links {
    order: 1;
    display: flex; gap: 1.6rem;
    justify-self: center;
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    backdrop-filter: blur(10px);
    padding: 0.7rem 1.4rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
    font-size: 0.7rem;
  }
  .nav-links a { transition: opacity 0.3s; }
  .nav-links a:hover { opacity: 0.5; }

  @media (max-width: 820px) {
    .nav-links { display: none; }
    .nav { grid-template-columns: 1fr; }
    .nav-logo { justify-self: end; }
  }

  /* ============================== */
  /*  COVER                          */
  /* ============================== */
  .cover {
    position: relative;
    min-height: 100svh;
    padding: clamp(4.5rem, 9vh, 8rem) var(--pad-x) clamp(2rem, 5vh, 4rem);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .cover::before,
  .cover::after {
    content: '';
    position: absolute; left: var(--pad-x); right: var(--pad-x);
    height: 1px;
    background: color-mix(in srgb, var(--fg) 20%, transparent);
    pointer-events: none;
  }
  .cover::before { top: clamp(3rem, 6vh, 5rem); }
  .cover::after { bottom: clamp(2rem, 4vh, 3.5rem); }

  .cover-folio-tl { top: clamp(3.4rem, 6.5vh, 5.6rem); left: var(--pad-x); }
  .cover-folio-tr { top: clamp(3.4rem, 6.5vh, 5.6rem); right: var(--pad-x); align-items: flex-end; }
  .cover-folio-bl { bottom: clamp(2.4rem, 4.5vh, 4rem); left: var(--pad-x); }
  .cover-folio-br { bottom: clamp(2.4rem, 4.5vh, 4rem); right: var(--pad-x); align-items: flex-end; }

  .cover-spine {
    position: absolute;
    left: clamp(0.8rem, 1.6vw, 1.6rem);
    top: 50%;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: center center;
    font-size: 0.65rem;
    letter-spacing: 0.32em;
    opacity: 0.5;
    white-space: nowrap;
    pointer-events: none;
  }

  .cover-stage {
    max-width: 1280px;
    width: 100%;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.8rem, 1.4vw, 1.4rem);
  }
  .cover-kicker {
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    opacity: 0.7;
  }
  .cover-headline {
    font-family: 'Fraunces', 'PP Editorial', serif;
    font-weight: 400;
    font-size: clamp(4.5rem, 18vw, 18rem);
    line-height: 0.86;
    letter-spacing: -0.04em;
    margin: 0;
    font-feature-settings: 'liga' 1, 'kern' 1, 'ss01' 1;
  }
  .cover-headline .ch-italic {
    font-style: italic;
    background: linear-gradient(180deg, var(--ink) 0%, var(--ink) 70%, color-mix(in srgb, var(--ink) 70%, var(--burgundy)) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .cover-headline .ch-period {
    color: var(--burgundy);
    font-size: 0.85em;
    margin-left: -0.04em;
  }

  .cover-deck {
    font-family: 'Fraunces', serif;
    font-size: clamp(1rem, 1.5vw, 1.45rem);
    line-height: 1.45;
    max-width: 32ch;
    opacity: 0.86;
  }
  .cover-deck em { font-style: italic; color: var(--burgundy); }
  .cover-year { font-style: italic; }

  .cover-rule {
    display: block;
    width: clamp(80px, 14vw, 180px);
    height: 1px;
    background: color-mix(in srgb, var(--fg) 60%, transparent);
    margin-block: clamp(0.6rem, 1vw, 1rem);
  }
  .cover-byline {
    font-size: 0.66rem;
    letter-spacing: 0.28em;
    opacity: 0.6;
    max-width: 60ch;
    line-height: 1.6;
  }

  @media (max-width: 720px) {
    .cover-spine { display: none; }
    .cover-folio-tl, .cover-folio-tr, .cover-folio-bl, .cover-folio-br {
      font-size: 0.55rem;
      letter-spacing: 0.18em;
    }
    .cover-headline { font-size: clamp(3.6rem, 22vw, 7rem); }
    .cover-deck { font-size: 0.95rem; max-width: 28ch; }
    .cover-byline { font-size: 0.55rem; letter-spacing: 0.18em; }
  }

  /* ============================== */
  /*  MASTHEAD / BY THE NUMBERS     */
  /* ============================== */
  .masthead {
    padding-block: clamp(4rem, 9vw, 9rem);
    border-top: 1px solid color-mix(in srgb, var(--fg) 14%, transparent);
  }
  .masthead-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    grid-template-rows: auto auto;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: end;
  }
  .masthead-intro {
    grid-column: 1; grid-row: 1 / span 2;
    display: flex; flex-direction: column; gap: 1.4rem;
    border-right: 1px solid color-mix(in srgb, var(--fg) 14%, transparent);
    padding-right: clamp(1.4rem, 3vw, 3rem);
  }
  .masthead-lead {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.4rem, 2.2vw, 2.2rem);
    line-height: 1.25;
    max-width: 26ch;
  }
  .masthead-lead em { font-style: italic; color: var(--burgundy); }

  .masthead-figure {
    display: flex; flex-direction: column; gap: 0.4rem;
    align-items: flex-start;
  }
  .masthead-figure-hero {
    grid-column: 2; grid-row: 1;
    align-items: flex-end;
    text-align: right;
  }
  .masthead-figure-hero figcaption { max-width: 24ch; text-align: right; }

  /* small figures stack inside col 2 row 2, asymmetric */
  .masthead-grid > .masthead-figure:not(.masthead-figure-hero):nth-of-type(2) {
    grid-column: 2; grid-row: 2;
    align-self: start;
    margin-top: 0;
  }
  .masthead-grid > .masthead-figure:not(.masthead-figure-hero):nth-of-type(3) {
    grid-column: 2; grid-row: 2;
    justify-self: center;
    align-self: start;
  }
  .masthead-grid > .masthead-figure:not(.masthead-figure-hero):nth-of-type(4) {
    grid-column: 2; grid-row: 2;
    justify-self: end;
    align-self: start;
    text-align: right;
  }
  .masthead-grid > .masthead-figure:not(.masthead-figure-hero):nth-of-type(4) figcaption {
    text-align: right; max-width: 18ch;
  }

  .masthead-num {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(5rem, 14vw, 14rem);
    line-height: 0.8;
    letter-spacing: -0.05em;
    font-style: italic;
    color: var(--burgundy);
  }
  .masthead-num-suffix {
    font-style: normal;
    color: var(--gold);
    font-size: 0.45em;
    margin-left: 0.05em;
  }
  .masthead-num-sm {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(3rem, 5vw, 5.4rem);
    line-height: 0.8;
    font-style: italic;
  }
  .masthead-figure figcaption {
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    opacity: 0.65;
    max-width: 22ch;
    line-height: 1.5;
  }
  .masthead-figure figcaption em { font-style: italic; color: var(--burgundy); }

  @media (max-width: 820px) {
    .masthead-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .masthead-intro {
      grid-row: auto; grid-column: auto;
      border-right: none;
      border-bottom: 1px solid color-mix(in srgb, var(--fg) 14%, transparent);
      padding: 0 0 1.6rem;
    }
    .masthead-figure-hero { grid-column: auto; grid-row: auto; align-items: flex-start; text-align: left; }
    .masthead-figure-hero figcaption { text-align: left; }
    .masthead-grid > .masthead-figure:not(.masthead-figure-hero) {
      grid-column: auto !important; grid-row: auto !important;
      justify-self: start !important; text-align: left !important;
    }
