---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Mattman Music — Independent label',
  description = 'Mattman Music — un label independent dedicat explorării noilor frontiere sonore. Patru artiști. O voce. Matteo, Andrei Bănuță, Georgiana Neagu, Emily Istrate.',
} = Astro.props;
---
<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F2EBE0" />

    <link rel="icon" type="image/png" href="/images/matteo/logo-black.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Unbounded:wght@200..900&display=swap"
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/mattman/logo-black.png" />

    <title>{title}</title>

    <style is:inline>
      :root { --font-display: 'Fraunces', 'Times New Roman', serif; }
      .huge { font-family: 'Fraunces', serif !important; }
      .display { font-family: 'Fraunces', serif !important; }
    </style>
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <div class="cursor" id="cursor" aria-hidden="true"></div>

    <slot />

    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // === LENIS SMOOTH SCROLL ===
      const lenis = new Lenis({
        duration: 1.15,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);

      // === CURSOR ===
      const cursor = document.getElementById('cursor');
      let mx = window.innerWidth / 2;
      let my = window.innerHeight / 2;
      let cx = mx, cy = my;
      window.addEventListener('mousemove', (e) => {
        mx = e.clientX; my = e.clientY;
      });
      const tick = () => {
        cx += (mx - cx) * 0.18;
        cy += (my - cy) * 0.18;
        if (cursor) cursor.style.transform = `translate(${cx}px, ${cy}px) translate(-50%, -50%)`;
        requestAnimationFrame(tick);
      };
      tick();
      document.querySelectorAll('a, button, .hover-target').forEach((el) => {
        el.addEventListener('mouseenter', () => cursor?.classList.add('is-hover'));
        el.addEventListener('mouseleave', () => cursor?.classList.remove('is-hover'));
      });

      // === MAGNETIC EFFECT ===
      document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((el) => {
        const strength = parseFloat(el.dataset.magnetic || '0.3');
        const reset = () => gsap.to(el, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1, 0.4)' });
        el.addEventListener('mousemove', (e) => {
          const r = el.getBoundingClientRect();
          const x = (e.clientX - (r.left + r.width / 2)) * strength;
          const y = (e.clientY - (r.top + r.height / 2)) * strength;
          gsap.to(el, { x, y, duration: 0.4, ease: 'power3.out' });
        });
        el.addEventListener('mouseleave', reset);
      });

      // === HERO LOGO MOUSE-TILT ===
      const heroLogoImg = document.querySelector<HTMLElement>('.hero-logo');
      if (heroLogoImg) {
        const stage = heroLogoImg.parentElement!;
        stage.addEventListener('mousemove', (e) => {
          const r = stage.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width - 0.5;
          const py = (e.clientY - r.top) / r.height - 0.5;
          gsap.to(heroLogoImg, {
            rotationY: px * 18,
            rotationX: -py * 12,
            x: px * 30,
            y: py * 20,
            duration: 0.9,
            ease: 'power3.out',
            transformPerspective: 1000,
          });
        });
        stage.addEventListener('mouseleave', () => {
          gsap.to(heroLogoImg, { rotationY: 0, rotationX: 0, x: 0, y: 0, duration: 1.2, ease: 'elastic.out(1, 0.5)' });
        });
      }

      // === SCRAMBLE TEXT ON HOVER ===
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%';
      document.querySelectorAll<HTMLElement>('[data-scramble]').forEach((el) => {
        const original = el.textContent || '';
        let frame = 0;
        let raf: number | null = null;
        const scramble = () => {
          const total = 22;
          const animate = () => {
            frame++;
            const out = original
              .split('')
              .map((c, i) => {
                if (frame > i + 6) return original[i];
                if (c === ' ') return ' ';
                return chars[Math.floor(Math.random() * chars.length)];
              })
              .join('');
            el.textContent = out;
            if (frame < total) raf = requestAnimationFrame(animate);
            else el.textContent = original;
          };
          frame = 0;
          if (raf) cancelAnimationFrame(raf);
          animate();
        };
        const parent = el.closest('[data-scramble-trigger]') || el;
        parent.addEventListener('mouseenter', scramble);
      });

      // === COUNTER ANIMATION ===
      document.querySelectorAll<HTMLElement>('[data-counter]').forEach((el) => {
        const target = parseFloat(el.dataset.counter || '0');
        const suffix = el.dataset.suffix || '';
        const decimals = parseInt(el.dataset.decimals || '0');
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 2.4,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 80%', once: true },
          onUpdate: () => {
            el.textContent = obj.val.toFixed(decimals).replace(/\B(?=(\d{3})+(?!\d))/g, ',') + suffix;
          },
        });
      });

      // === SECTION COUNTER (right-edge indicator) ===
      const sectionLabels = ['HERO', 'STATS', 'MANIFEST', 'ROSTER', 'CATALOG', 'BOOKING'];
      const sectionEls = [
        document.querySelector('.hero'),
        document.querySelector('.stats'),
        document.querySelector('.mattman'),
        document.querySelector('.roster'),
        document.querySelector('.discography'),
        document.querySelector('.booking'),
      ].filter(Boolean) as HTMLElement[];
      const sectionCounter = document.getElementById('section-counter');
      const sectionLabel = document.getElementById('section-label');
      sectionEls.forEach((el, i) => {
        ScrollTrigger.create({
          trigger: el,
          start: 'top 50%',
          end: 'bottom 50%',
          onEnter: () => updateSectionCounter(i),
          onEnterBack: () => updateSectionCounter(i),
        });
      });
      function updateSectionCounter(i: number) {
        if (sectionCounter) sectionCounter.textContent = String(i + 1).padStart(2, '0') + ' / ' + String(sectionEls.length).padStart(2, '0');
        if (sectionLabel) sectionLabel.textContent = sectionLabels[i];
      }
      updateSectionCounter(0);

      // === SOUND BARS ANIMATION (marquee bars) ===
      document.querySelectorAll<HTMLElement>('.sound-bar').forEach((bar, i) => {
        gsap.to(bar, {
          scaleY: 0.3 + Math.random() * 0.7,
          duration: 0.4 + Math.random() * 0.4,
          ease: 'sine.inOut',
          repeat: -1,
          yoyo: true,
          delay: i * 0.05,
          transformOrigin: '50% 100%',
        });
      });

      // === REVEAL ANIMATIONS ===
      document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
        gsap.fromTo(
          el,
          { y: 60, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 1.2,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              once: true,
            },
          }
        );
      });

      // Split-line reveal for [data-reveal-lines]
      document.querySelectorAll<HTMLElement>('[data-reveal-lines]').forEach((el) => {
        const lines = el.querySelectorAll<HTMLElement>('.reveal-line > span');
        gsap.fromTo(
          lines,
          { y: '110%' },
          {
            y: '0%',
            duration: 1.4,
            ease: 'expo.out',
            stagger: 0.08,
            scrollTrigger: {
              trigger: el,
              start: 'top 80%',
              once: true,
            },
          }
        );
      });

      // === SCROLL-SCRUBBED BG COLOR (cream → black on Mattman + Roster) ===
      const darkAnchor = document.querySelector<HTMLElement>('[data-bg="dark"]');
      const lightEnd = document.querySelector<HTMLElement>('[data-bg="light-end"]');
      if (darkAnchor && lightEnd) {
        ScrollTrigger.create({
          trigger: darkAnchor,
          start: 'top 60%',
          endTrigger: lightEnd,
          end: 'top 60%',
          toggleClass: { targets: 'body', className: 'dark' },
        });
      }

      // === HERO PORTRAIT PARALLAX ===
      const heroPortraitImg = document.querySelector<HTMLElement>('.hero-portrait img');
      if (heroPortraitImg) {
        gsap.to(heroPortraitImg, {
          yPercent: -10,
          ease: 'none',
          scrollTrigger: {
            trigger: '.hero-portrait',
            start: 'top top',
            end: 'bottom top',
            scrub: 1,
          },
        });
      }

      // === HERO SONIC ECHO + VARIABLE PROXIMITY (reactbits-style) ===
      const heroSonic = document.querySelector<HTMLElement>('[data-hero-sonic]');
      const heroMark = document.querySelector<HTMLElement>('[data-hero-mark]');
      const heroMain = document.querySelector<HTMLElement>('.hero-main');

      // Fit-to-width — measure rendered width at 100px and scale to fill container
      const fitMark = () => {
        if (!heroMark || !heroMain) return;
        const wrap = heroMark; // .hero-echo-wrap
        const containerW = wrap.clientWidth;
        if (containerW === 0) return;
        const tester = document.createElement('span');
        tester.style.cssText = [
          'position:fixed', 'visibility:hidden', 'pointer-events:none',
          'left:-9999px', 'top:0',
          "font-family:'Unbounded','Inter',sans-serif",
          'font-weight:900', "font-variation-settings:'wght' 900",
          'letter-spacing:-0.035em', 'text-transform:uppercase',
          'white-space:nowrap', 'font-size:100px',
        ].join(';');
        tester.textContent = 'MATTMAN';
        document.body.appendChild(tester);
        const renderedAt100 = tester.getBoundingClientRect().width;
        document.body.removeChild(tester);
        if (renderedAt100 === 0) return;
        // target width = 96% of container, scale font-size accordingly
        const targetWidth = containerW * 0.96;
        const idealPx = (targetWidth / renderedAt100) * 100;
        // hard cap at ~288px (18rem) so it doesn't go absurd on huge displays
        const finalPx = Math.max(28, Math.min(288, idealPx));
        const els = [heroMain, ...wrap.querySelectorAll<HTMLElement>('.hero-echo')];
        els.forEach((el) => {
          el.style.fontSize = `${finalPx}px`;
        });
      };
      if (heroMark) {
        fitMark();
        window.addEventListener('resize', fitMark, { passive: true });
        // refit when fonts finish loading (Unbounded)
        document.fonts.ready.then(() => fitMark());
      }

      if (heroSonic && heroMark && heroMain) {
        const chars = Array.from(heroMain.querySelectorAll<HTMLElement>('.hm-char'));
        const echoes = Array.from(heroSonic.querySelectorAll<HTMLElement>('.hero-echo'));

        // Load reveal — main letters rise from mask
        gsap.to(chars, {
          y: 0,
          duration: 1.4,
          ease: 'expo.out',
          stagger: 0.06,
          delay: 0.2,
          onStart: () => {
            heroMain.classList.add('is-loaded');
            heroMark.classList.add('is-loaded');
            heroSonic.setAttribute('data-loaded', '');
          },
        });

        // Sonar echoes — concentric ripples
        echoes.forEach((echo, i) => {
          const baseScale = 1 + (i + 1) * 0.08;
          const targetScale = baseScale + 0.18;
          gsap.fromTo(
            echo,
            { opacity: 0, scale: baseScale },
            {
              opacity: 0.35 - i * 0.07,
              scale: baseScale,
              duration: 1.2,
              delay: 1 + i * 0.15,
              ease: 'power2.out',
              onComplete: () => {
                gsap.to(echo, {
                  scale: targetScale,
                  opacity: 0,
                  duration: 4 + i * 0.4,
                  ease: 'sine.inOut',
                  repeat: -1,
                  delay: i * 0.6,
                  onRepeat: () => {
                    gsap.set(echo, { scale: baseScale, opacity: 0.35 - i * 0.07 });
                  },
                });
              },
            }
          );
        });

        // Variable Proximity — letters morph weight based on cursor distance
        // Reactbits-inspired: gaussian falloff, interpolated 'wght' variation axis
        const FROM_WGHT = 250;
        const TO_WGHT = 900;
        const RADIUS = 260;
        const cursor = { x: -10000, y: -10000 };
        let lastX = cursor.x, lastY = cursor.y;
        let active = false;

        const onMove = (e: PointerEvent) => {
          cursor.x = e.clientX; cursor.y = e.clientY; active = true;
        };
        const onLeave = () => { active = false; };
        window.addEventListener('pointermove', onMove);
        heroMark.addEventListener('pointerleave', onLeave);

        // Initial weight per char (light)
        chars.forEach((ch) => {
          ch.style.fontVariationSettings = `'wght' ${FROM_WGHT}`;
        });

        const tickWeight = () => {
          if (cursor.x === lastX && cursor.y === lastY && !active) {
            // gentle decay back to base when no movement detected
            chars.forEach((ch) => {
              const cur = parseFloat(ch.dataset.wght || String(FROM_WGHT));
              const next = cur + (FROM_WGHT - cur) * 0.05;
              ch.dataset.wght = String(next);
              ch.style.fontVariationSettings = `'wght' ${next}`;
            });
            requestAnimationFrame(tickWeight);
            return;
          }
          lastX = cursor.x; lastY = cursor.y;
          chars.forEach((ch) => {
            const r = ch.getBoundingClientRect();
            const cx = r.left + r.width / 2;
            const cy = r.top + r.height / 2;
            const dist = Math.hypot(cursor.x - cx, cursor.y - cy);
            // gaussian falloff for buttery bell curve
            const sigma = RADIUS / 2;
            const falloff = active ? Math.exp(-((dist / sigma) ** 2) / 2) : 0;
            const wght = FROM_WGHT + (TO_WGHT - FROM_WGHT) * falloff;
            ch.dataset.wght = String(wght);
            ch.style.fontVariationSettings = `'wght' ${wght}`;
          });
          requestAnimationFrame(tickWeight);
        };
        requestAnimationFrame(tickWeight);
      }

      // === BLUR TEXT (reactbits-style) — word-by-word blur reveal ===
      document.querySelectorAll<HTMLElement>('[data-blur-text]').forEach((el) => {
        const words = el.querySelectorAll<HTMLElement>('.bt-word');
        ScrollTrigger.create({
          trigger: el,
          start: 'top 80%',
          once: true,
          onEnter: () => {
            words.forEach((w, i) => {
              setTimeout(() => w.classList.add('is-in'), i * 110);
            });
          },
        });
      });

      // === SCROLL VELOCITY MARQUEE (reactbits-style) ===
      // Marquee speed scales with current scroll velocity; fast scrolls add a slight skew
      const marqueeTrack = document.querySelector<HTMLElement>('[data-scroll-velocity-track]');
      const marqueeWrap = document.querySelector<HTMLElement>('[data-scroll-velocity]');
      if (marqueeTrack && marqueeWrap) {
        marqueeTrack.style.animation = 'none';
        let offset = 0;
        let lastScroll = window.scrollY;
        let velocity = 0;
        let baseSpeed = 0.6;
        let lastT = performance.now();

        window.addEventListener('scroll', () => {
          const cur = window.scrollY;
          const v = cur - lastScroll;
          lastScroll = cur;
          velocity = v;
        }, { passive: true });

        const trackTick = () => {
          const now = performance.now();
          const dt = Math.min(40, now - lastT);
          lastT = now;
          // boost speed by abs velocity, decay velocity
          const boost = Math.min(8, Math.abs(velocity) * 0.4);
          const dir = velocity >= 0 ? 1 : -1;
          const speed = (baseSpeed + boost) * dir;
          offset -= speed * (dt / 16);
          // half-width loop (track has 2x duplicated content)
          const half = marqueeTrack.scrollWidth / 2;
          if (-offset >= half) offset += half;
          if (-offset < 0) offset -= half;
          // skew during high velocity
          const skew = Math.max(-6, Math.min(6, -velocity * 0.25));
          marqueeTrack.style.transform = `translateX(${offset}px) skewX(${skew}deg)`;
          velocity *= 0.92;
          requestAnimationFrame(trackTick);
        };
        requestAnimationFrame(trackTick);
      }

      // === DECRYPTED TEXT on Catalog tracks (reactbits-inspired) ===
      const cipher = '!@#$%&*()_+=[]{}|<>?ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
      document.querySelectorAll<HTMLElement>('[data-decrypt]').forEach((el) => {
        const original = el.textContent || '';
        let revealed = new Array(original.length).fill(false);
        let raf: number | null = null;
        const tick = () => {
          let allRevealed = true;
          const out = original
            .split('')
            .map((c, i) => {
              if (c === ' ') return ' ';
              if (revealed[i]) return original[i];
              if (Math.random() < 0.04) revealed[i] = true;
              else allRevealed = false;
              return cipher[Math.floor(Math.random() * cipher.length)];
            })
            .join('');
          el.textContent = out;
          if (!allRevealed) raf = requestAnimationFrame(tick);
          else el.textContent = original;
        };
        const start = () => {
          if (raf) cancelAnimationFrame(raf);
          revealed = new Array(original.length).fill(false);
          tick();
        };
        const parent = el.closest('[data-scramble-trigger]') || el;
        parent.addEventListener('mouseenter', start);
      });

      // === HUGE TYPE PARALLAX ===
      document.querySelectorAll<HTMLElement>('[data-parallax]').forEach((el) => {
        const speed = parseFloat(el.dataset.parallax || '-0.2');
        gsap.to(el, {
          yPercent: speed * 100,
          ease: 'none',
          scrollTrigger: {
            trigger: el,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1,
          },
        });
      });

      // Refresh after fonts load
      document.fonts.ready.then(() => ScrollTrigger.refresh());
    </script>
  </body>
</html>
