---
import Layout from '../layouts/Layout.astro';

const tracks = [
  { year: '2006', title: 'Departare', feat: 'feat. Loredana', note: 'Debut' },
  { year: '2010', title: 'Lovaman', feat: 'EP' },
  { year: '2012', title: 'Push It', feat: 'feat. Stella' },
  { year: '2013', title: 'Amândoi' },
  { year: '2013', title: 'Panama', note: '225M+', highlight: true },
  { year: '2014', title: 'Andale' },
  { year: '2015', title: 'Gândesc cu voce tare' },
  { year: '2017', title: 'Bună, Marie!', feat: 'feat. Uddi' },
  { year: '2018', title: 'Allegro Ventigo', feat: 'feat. Dan Bălan', highlight: true },
  { year: '2021', title: 'Copacul', feat: 'feat. Theo Rose' },
  { year: '2023', title: 'Lato Lato', feat: 'feat. Sean Al' },
  { year: '2025', title: 'Gypsy Reggae', feat: 'EP', highlight: true },
];

const roster = [
  {
    slug: 'matteo',
    name: 'Matteo',
    role: 'Founder',
    tagline: 'Two decades. Hit after hit.',
    bio: 'Founder of Mattman Music. Almost two decades of hits — debut "Departare" (2006, with Loredana). Most viral single "Panama" — 225M+ views, going global on TikTok across Asia. Latest venture: a self-coined fusion genre, Gypsy Reggae, with King Kong, Anthony B, Loyal Flames and Johny Romano.',
    photo: '/images/matteo/portrait-md.jpg',
  },
  {
    slug: 'andrei',
    name: 'Andrei Bănuță',
    role: 'Artist',
    tagline: 'An artist of contrasts.',
    bio: 'One of the most in-demand voices today. Songwriting that alternates between deep, meaningful lyrics and vibrant, playful songs. Best known for "Suflet de Bagabond" (90M+ views) and "Old Friend" with Vescan — over 10 weeks atop the Media Forest Chart.',
    photo: '/images/roster/andrei.jpg',
  },
  {
    slug: 'georgiana',
    name: 'Georgiana Neagu',
    role: 'Artist',
    tagline: 'The new wave of balkan pop.',
    bio: 'A new wave of Romanian balkan pop. Contemporary sound and relatable lyrics that connect with a young audience nationwide. "M-am Îndrăgostit de Tine (Vreau să facem o fetiță)" — viral on TikTok, 2.2M+ views on YouTube.',
    photo: '/images/roster/georgiana.jpg',
  },
  {
    slug: 'emily',
    name: 'Emily Istrate',
    role: 'Artist',
    tagline: 'Beautiful, talented, charismatic.',
    bio: 'Singer, songwriter, actress from the Republic of Moldova. International recognition with "If You Want To" and "Panic" — UK Pop Club Charts #4 and #5. 2023 saw her climb the top of major Romanian charts with "Bye Bye Boy" and "În Mintea Mea".',
    photo: '/images/roster/emily.jpg',
  },
];
---
<Layout>
  <!-- NAV -->
  <nav class="nav">
    <a href="#top" class="nav-brand hover-target">
      <span class="nav-brand-mark">Mattman</span>
      <span class="nav-brand-tag mono">Music · MMVI</span>
    </a>
    <ul class="nav-links mono">
      <li><a href="#statement">Statement</a></li>
      <li><a href="#roster">Roster</a></li>
      <li><a href="#catalog">Catalog</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- ============================== -->
  <!--  HERO — record-sleeve cover     -->
  <!-- ============================== -->
  <section class="hero" id="top">
    <div class="hero-frame">
      <div class="hero-media" data-cover-media>
        <img src="/images/matteo/portrait-md.jpg" alt="" data-parallax-img />
      </div>
      <div class="hero-veil" aria-hidden="true"></div>
      <div class="hero-grade" aria-hidden="true"></div>
    </div>

    <div class="hero-grid">
      <div class="hero-tl">
        <span class="mono hero-tl-1">A0:</span>
        <span class="mono hero-tl-2">Mattman Music</span>
        <span class="mono hero-tl-3">An independent label · București</span>
      </div>

      <div class="hero-tr">
        <span class="mono">Est. 2006</span>
      </div>

      <h1 class="hero-headline">
        <span class="hl-line hl-line-1" data-line>Independent</span>
        <span class="hl-line hl-line-2" data-line>sound,</span>
        <span class="hl-line hl-line-3" data-line><em>since</em> 2006.</span>
      </h1>

      <div class="hero-meta">
        <span class="mono hero-meta-roster">— Matteo · Andrei Bănuță · Georgiana Neagu · Emily Istrate</span>
      </div>

      <div class="hero-bl">
        <span class="mono">Scroll ↓</span>
      </div>

      <div class="hero-br">
        <span class="mono">001 / 005</span>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!--  STATEMENT (single block)       -->
  <!-- ============================== -->
  <section class="statement" id="statement" data-bg="dark">
    <div class="statement-rail">
      <span class="mono">— 002 / Statement</span>
    </div>

    <div class="statement-body">
      <h2 class="statement-text" data-blur-text>
        <span class="bt-word">Mattman</span>
        <span class="bt-word">Music</span>
        <span class="bt-word">este</span>
        <span class="bt-word">un</span>
        <span class="bt-word">label</span>
        <span class="bt-word">independent</span>
        <span class="bt-word">care</span>
        <span class="bt-word">a</span>
        <span class="bt-word">construit,</span>
        <span class="bt-word">timp</span>
        <span class="bt-word">de</span>
        <span class="bt-word">două</span>
        <span class="bt-word">decenii,</span>
        <span class="bt-word">un</span>
        <span class="bt-word">catalog</span>
        <span class="bt-word">de</span>
        <span class="bt-word">hituri</span>
        <span class="bt-word">care</span>
        <span class="bt-word">au</span>
        <span class="bt-word">plecat</span>
        <span class="bt-word">din</span>
        <span class="bt-word">București</span>
        <span class="bt-word">spre</span>
        <span class="bt-word st-em">o</span>
        <span class="bt-word st-em">audiență</span>
        <span class="bt-word st-em">globală.</span>
      </h2>

      <div class="statement-figures">
        <div class="figure-row">
          <span class="figure-num">225M+</span>
          <span class="mono figure-label">Vizualizări · Panama (2013)</span>
        </div>
        <div class="figure-row">
          <span class="figure-num">12</span>
          <span class="mono figure-label">Single-uri în catalog</span>
        </div>
        <div class="figure-row">
          <span class="figure-num">9+</span>
          <span class="mono figure-label">Țări — viral abroad</span>
        </div>
        <div class="figure-row">
          <span class="figure-num">4</span>
          <span class="mono figure-label">Voci pe roster</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!--  ROSTER — cinematic features    -->
  <!-- ============================== -->
  <section class="roster" id="roster">
    <header class="roster-head">
      <span class="mono">— 003 / Roster</span>
      <h2 class="roster-title">
        Four artists.<br>One catalog.
      </h2>
    </header>

    {roster.map((r, i) => (
      <article class={`feature feature-${r.slug}`} data-feature data-feature-index={i}>
        <div class="feature-frame">
          <div class="feature-media" data-cover-media>
            <img src={r.photo} alt={r.name} loading="lazy" data-parallax-img />
          </div>
          <div class="feature-veil" aria-hidden="true"></div>
          <div class="feature-grade" aria-hidden="true"></div>
        </div>

        <div class="feature-grid">
          <div class="feature-num">
            <span class="mono">№ {String(i + 1).padStart(2, '0')} / 04</span>
          </div>
          <div class="feature-role">
            <span class="mono">{r.role}</span>
          </div>

          <h3 class="feature-name" data-feature-name>
            <span>{r.name}</span>
          </h3>

          <div class="feature-text">
            <span class="mono feature-tag">{r.tagline}</span>
            <p class="feature-bio">{r.bio}</p>
          </div>
        </div>
      </article>
    ))}
  </section>

  <!-- ============================== -->
  <!--  CATALOG — chronological ledger -->
  <!-- ============================== -->
  <section class="catalog" id="catalog">
    <header class="catalog-head">
      <div class="catalog-rail">
        <span class="mono">— 004 / Catalog</span>
        <span class="mono">2006 — 2025</span>
      </div>
      <h2 class="catalog-title">
        Twelve singles.<br>
        <span class="catalog-title-2">Two decades on record.</span>
      </h2>
    </header>

    <ol class="ledger">
      {tracks.map((t, i) => (
        <li class={`ledger-row ${t.highlight ? 'is-key' : ''}`} data-scramble-trigger>
          <span class="ledger-idx mono">{String(i + 1).padStart(2, '0')}</span>
          <span class="ledger-year mono">{t.year}</span>
          <span class="ledger-title">
            <span data-decrypt>{t.title}</span>
          </span>
          <span class="ledger-feat mono">{t.feat || ''}</span>
          <span class="ledger-note mono">{t.note || ''}</span>
        </li>
      ))}
    </ol>
  </section>

  <!-- ============================== -->
  <!--  CONTACT                         -->
  <!-- ============================== -->
  <section class="contact" id="contact">
    <header class="contact-head">
      <span class="mono">— 005 / Contact</span>
    </header>

    <h2 class="contact-headline">
      Work with<br>
      <em>the label.</em>
    </h2>

    <div class="contact-block">
      <a href="mailto:booking@mattmanmusic.com" class="contact-line hover-target">
        <span class="mono contact-line-tag">Booking · Management</span>
        <span class="contact-line-mail">booking@mattmanmusic.com</span>
        <span class="mono contact-line-arrow">↗</span>
      </a>
      <a href="mailto:hello@mattmanmusic.com" class="contact-line hover-target">
        <span class="mono contact-line-tag">Press · Label</span>
        <span class="contact-line-mail">hello@mattmanmusic.com</span>
        <span class="mono contact-line-arrow">↗</span>
      </a>
    </div>
  </section>

  <!-- ============================== -->
  <!--  COLOPHON                       -->
  <!-- ============================== -->
  <footer class="colophon">
    <span class="mono">© Mattman Music · 2006 — {new Date().getFullYear()}</span>
    <a href="https://youtube.com/@mattmanmusic" target="_blank" rel="noopener" class="mono hover-target">YouTube ↗</a>
    <span class="mono">Site · <a href="https://grappes.ai" target="_blank" rel="noopener" class="hover-target">Grappes</a></span>
  </footer>
</Layout>

<style>
  /* ============================== */
  /*  GLOBAL                         */
  /* ============================== */
  body {
    background: var(--bone);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }
  body.dark {
    background: var(--ink);
    color: var(--bone);
  }
  ::selection { background: var(--persimmon); color: var(--bone); }

  .mono {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.4;
  }

  /* ============================== */
  /*  NAV                           */
  /* ============================== */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: grid; grid-template-columns: 1fr auto 1fr;
    align-items: center; gap: 2rem;
    padding: 1.4rem clamp(1.2rem, 3vw, 3rem);
    pointer-events: none;
    mix-blend-mode: difference;
    color: var(--bone);
  }
  .nav > * { pointer-events: auto; }
  .nav-brand { display: inline-flex; flex-direction: column; gap: 0.1rem; line-height: 1; }
  .nav-brand-mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.03em;
  }
  .nav-brand-tag { font-size: 0.55rem; opacity: 0.7; letter-spacing: 0.22em; }
  .nav-links {
    justify-self: end;
    display: flex; gap: 1.4rem;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
  }
  .nav-links a { transition: opacity 0.3s; opacity: 0.78; }
  .nav-links a:hover { opacity: 1; }

  @media (max-width: 820px) {
    .nav { grid-template-columns: 1fr auto; gap: 1rem; }
    .nav-links { display: none; }
  }

  /* ============================== */
  /*  HERO — record-sleeve cover     */
  /* ============================== */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    isolation: isolate;
    background: var(--ink);
    color: var(--bone);
  }
  .hero-frame { position: absolute; inset: 0; overflow: hidden; z-index: 0; }
  .hero-media {
    position: absolute;
    inset: -8% -4%;
    will-change: transform;
  }
  .hero-media img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 28%;
    filter: contrast(1.08) saturate(0.78) brightness(0.86);
    animation: kenburns 26s ease-in-out infinite alternate;
  }
  @keyframes kenburns {
    0% { transform: scale(1.04) translate(0, 0); }
    100% { transform: scale(1.13) translate(-1%, -2%); }
  }
  .hero-veil {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(11,11,11,0.42) 0%, rgba(11,11,11,0.05) 30%, rgba(11,11,11,0.55) 78%, rgba(11,11,11,0.95) 100%);
    z-index: 1;
  }
  .hero-grade {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 70% 30%, rgba(199,61,23,0.15) 0%, rgba(199,61,23,0) 60%);
    mix-blend-mode: overlay;
    z-index: 2;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute; inset: 0;
    z-index: 3;
    padding: clamp(5.5rem, 10vh, 8rem) clamp(1.4rem, 3vw, 3rem) clamp(2rem, 5vh, 4rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr auto auto;
    grid-template-areas:
      "tl tr"
      "headline headline"
      "meta meta"
      "bl br";
    gap: 1.6rem;
    color: var(--bone);
  }
  .hero-tl { grid-area: tl; display: flex; flex-direction: column; gap: 0.4rem; opacity: 0.86; }
  .hero-tl-1 { color: var(--persimmon-soft); }
  .hero-tr { grid-area: tr; justify-self: end; opacity: 0.78; }
  .hero-bl { grid-area: bl; align-self: end; opacity: 0.78; }
  .hero-br { grid-area: br; justify-self: end; align-self: end; opacity: 0.78; }

  .hero-headline {
    grid-area: headline;
    align-self: end;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(3.4rem, 12vw, 13rem);
    line-height: 0.88;
    letter-spacing: -0.045em;
  }
  .hl-line { display: block; overflow: hidden; line-height: 0.95; padding-bottom: 0.06em; }
  .hl-line span,
  .hl-line { will-change: transform; }
  .hl-line {
    transform: translateY(110%);
    transition: transform 1.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hl-line-2 { transition-delay: 0.12s; }
  .hl-line-3 { transition-delay: 0.24s; }
  body[data-loaded] .hl-line { transform: translateY(0); }
  .hl-line em {
    font-style: italic;
    font-weight: 600;
    color: var(--persimmon-soft);
  }

  .hero-meta {
    grid-area: meta;
    align-self: end;
    border-top: 1px solid rgba(240,237,227,0.22);
    padding-top: 1rem;
    margin-top: 1.2rem;
  }
  .hero-meta-roster { letter-spacing: 0.18em; opacity: 0.72; }

  @media (max-width: 720px) {
    .hero-headline { font-size: clamp(2.8rem, 14vw, 5.4rem); }
    .hero-tl-3 { display: none; }
    .hero-meta-roster { font-size: 0.5rem; letter-spacing: 0.14em; }
  }

  /* ============================== */
  /*  STATEMENT                      */
  /* ============================== */
  .statement {
    background: var(--ink);
    color: var(--bone);
    padding: clamp(6rem, 14vh, 12rem) clamp(1.4rem, 3vw, 3rem);
    display: grid;
    grid-template-columns: minmax(0, 12rem) 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    border-top: 1px solid rgba(240,237,227,0.12);
  }
  .statement-rail { padding-top: 0.5rem; opacity: 0.62; }
  .statement-body { display: flex; flex-direction: column; gap: clamp(3rem, 6vh, 5rem); max-width: 70rem; }
  .statement-text {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.7rem, 3.6vw, 3.8rem);
    line-height: 1.18;
    letter-spacing: -0.018em;
    max-width: 32ch;
  }
  .statement-text .st-em { color: var(--persimmon-soft); font-weight: 600; }
  .statement-text .bt-word { margin-right: 0.22em; }

  .statement-figures {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem) clamp(2.5rem, 5vw, 5rem);
    border-top: 1px solid rgba(240,237,227,0.18);
    padding-top: clamp(2rem, 4vh, 3rem);
    max-width: 60rem;
  }
  .figure-row {
    display: flex; align-items: baseline; gap: 1.4rem;
    border-bottom: 1px solid rgba(240,237,227,0.12);
    padding-bottom: 1.2rem;
  }
  .figure-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 4.5vw, 4.4rem);
    line-height: 0.9;
    letter-spacing: -0.025em;
    color: var(--bone);
  }
  .figure-label { opacity: 0.62; max-width: 22ch; line-height: 1.4; }

  @media (max-width: 820px) {
    .statement { grid-template-columns: 1fr; }
    .statement-figures { grid-template-columns: 1fr; gap: 1rem; }
  }
  @media (max-width: 480px) {
    .statement-text { font-size: clamp(1.3rem, 6.5vw, 2rem); max-width: none; }
  }

  /* ============================== */
  /*  ROSTER FEATURES                */
  /* ============================== */
  .roster {
    background: var(--bone);
    color: var(--ink);
    padding-top: clamp(4rem, 8vh, 7rem);
  }
  .roster-head {
    padding: 0 clamp(1.4rem, 3vw, 3rem) clamp(2rem, 5vh, 4rem);
    display: flex;
    flex-direction: column;
    gap: clamp(1.2rem, 2.5vh, 2rem);
    border-bottom: 1px solid rgba(11,11,11,0.16);
  }
  .roster-head .mono { color: var(--persimmon); opacity: 0.85; }
  .roster-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.6rem, 7.5vw, 7.6rem);
    line-height: 0.92;
    letter-spacing: -0.035em;
  }

  .feature {
    position: relative;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    isolation: isolate;
    background: var(--ink);
    color: var(--bone);
    border-top: 1px solid rgba(11,11,11,0.16);
  }
  .feature-frame { position: absolute; inset: 0; overflow: hidden; z-index: 0; }
  .feature-media { position: absolute; inset: -8% -4%; will-change: transform; }
  .feature-media img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 22%;
    filter: contrast(1.08) saturate(0.8) brightness(0.84);
    animation: kenburns 28s ease-in-out infinite alternate;
  }
  .feature-andrei .feature-media img { object-position: center 18%; animation-duration: 26s; }
  .feature-georgiana .feature-media img { object-position: center 26%; }
  .feature-emily .feature-media img { object-position: center 30%; animation-duration: 30s; }
  .feature-veil {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(11,11,11,0.45) 0%, rgba(11,11,11,0.1) 28%, rgba(11,11,11,0.65) 78%, rgba(11,11,11,0.95) 100%);
    z-index: 1;
  }
  .feature-grade {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 70%, rgba(199,61,23,0.12) 0%, rgba(199,61,23,0) 60%);
    mix-blend-mode: overlay;
    z-index: 2;
    pointer-events: none;
  }

  .feature-grid {
    position: absolute; inset: 0;
    z-index: 3;
    padding: clamp(4.5rem, 8vh, 7rem) clamp(1.4rem, 3vw, 3rem) clamp(2rem, 5vh, 4rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr auto;
    grid-template-areas:
      "num role"
      "name name"
      "text text";
    gap: 1.6rem;
  }
  .feature-num { grid-area: num; opacity: 0.78; }
  .feature-role { grid-area: role; justify-self: end; opacity: 0.78; }
  .feature-role .mono { color: var(--persimmon-soft); }

  .feature-name {
    grid-area: name;
    align-self: end;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(3.4rem, 12vw, 13rem);
    line-height: 0.86;
    letter-spacing: -0.045em;
    overflow: hidden;
    color: var(--bone);
  }
  .feature-name span {
    display: block;
    transform: translateY(110%);
    transition: transform 1.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .feature[data-in] .feature-name span { transform: translateY(0); }

  .feature-text {
    grid-area: text;
    border-top: 1px solid rgba(240,237,227,0.22);
    padding-top: 1rem;
    margin-top: 1rem;
    display: grid;
    grid-template-columns: minmax(0, 22rem) minmax(0, 56ch);
    gap: clamp(1.5rem, 4vw, 4rem);
  }
  .feature-tag { color: var(--persimmon-soft); opacity: 0.95; align-self: start; }
  .feature-bio {
    font-family: var(--font-body);
    font-size: clamp(0.85rem, 1vw, 1.02rem);
    line-height: 1.55;
    opacity: 0.92;
    max-width: 56ch;
  }

  @media (max-width: 820px) {
    .feature-text { grid-template-columns: 1fr; gap: 0.8rem; }
    .feature-name { font-size: clamp(2.4rem, 14vw, 5rem); }
  }

  /* ============================== */
  /*  CATALOG                        */
  /* ============================== */
  .catalog {
    background: var(--bone);
    color: var(--ink);
    padding: clamp(5rem, 10vh, 9rem) clamp(1.4rem, 3vw, 3rem);
    border-top: 1px solid rgba(11,11,11,0.16);
  }
  .catalog-head {
    display: grid;
