---
import Layout from '../layouts/Layout.astro';

const tracks = [
  { year: '2006', title: 'Departare', feat: 'feat. Loredana', note: 'Debut' },
  { year: '2010', title: 'Lovaman', feat: 'EP' },
  { year: '2012', title: 'Push It', feat: 'feat. Stella' },
  { year: '2013', title: 'Amândoi' },
  { year: '2013', title: 'Panama', note: '225M+', highlight: true },
  { year: '2014', title: 'Andale' },
  { year: '2015', title: 'Gândesc cu voce tare' },
  { year: '2017', title: 'Bună, Marie!', feat: 'feat. Uddi' },
  { year: '2018', title: 'Allegro Ventigo', feat: 'feat. Dan Bălan', highlight: true },
  { year: '2021', title: 'Copacul', feat: 'feat. Theo Rose' },
  { year: '2023', title: 'Lato Lato', feat: 'feat. Sean Al' },
  { year: '2025', title: 'Gypsy Reggae', feat: 'EP', highlight: true },
];

const roster = [
  {
    slug: 'matteo',
    name: 'Matteo',
    role: 'Founder',
    tagline: 'Two decades. Hit after hit.',
    bio: 'Founder of Mattman Music. Almost two decades of hits — debut "Departare" (2006, with Loredana). Most viral single "Panama" — 225M+ views, going global on TikTok across Asia. Latest venture: a self-coined fusion genre, Gypsy Reggae, with King Kong, Anthony B, Loyal Flames and Johny Romano.',
    photo: '/images/matteo/portrait-md.jpg',
  },
  {
    slug: 'andrei',
    name: 'Andrei Bănuță',
    role: 'Artist',
    tagline: 'An artist of contrasts.',
    bio: 'One of the most in-demand voices today. Songwriting that alternates between deep, meaningful lyrics and vibrant, playful songs. Best known for "Suflet de Bagabond" (90M+ views) and "Old Friend" with Vescan — over 10 weeks atop the Media Forest Chart.',
    photo: '/images/roster/andrei.jpg',
  },
  {
    slug: 'georgiana',
    name: 'Georgiana Neagu',
    role: 'Artist',
    tagline: 'The new wave of balkan pop.',
    bio: 'A new wave of Romanian balkan pop. Contemporary sound and relatable lyrics that connect with a young audience nationwide. "M-am Îndrăgostit de Tine (Vreau să facem o fetiță)" — viral on TikTok, 2.2M+ views on YouTube.',
    photo: '/images/roster/georgiana.jpg',
  },
  {
    slug: 'emily',
    name: 'Emily Istrate',
    role: 'Artist',
    tagline: 'Beautiful, talented, charismatic.',
    bio: 'Singer, songwriter, actress from the Republic of Moldova. International recognition with "If You Want To" and "Panic" — UK Pop Club Charts #4 and #5. 2023 saw her climb the top of major Romanian charts with "Bye Bye Boy" and "În Mintea Mea".',
    photo: '/images/roster/emily.jpg',
  },
];
---
<Layout>
  <!-- NAV -->
  <nav class="nav">
    <a href="#top" class="nav-logo hover-target" data-magnetic="0.4">
      <img src="/images/mattman/logo-black.png" alt="Mattman Music" class="nav-logo-img" />
    </a>
    <ul class="nav-links mono">
      <li><a href="#statement">Statement</a></li>
      <li><a href="#roster">Roster</a></li>
      <li><a href="#catalog">Catalog</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- ============================== -->
  <!-- 01 — COVER (full-bleed, kinetic)-->
  <!-- ============================== -->
  <section class="cover" id="top">
    <div class="cover-frame">
      <div class="cover-media" data-cover-media>
        <img src="/images/matteo/portrait-md.jpg" alt="" class="cover-img" data-parallax-img />
      </div>
      <div class="cover-veil" aria-hidden="true"></div>
    </div>

    <span class="cover-rule cover-rule-l" aria-hidden="true"></span>
    <span class="cover-rule cover-rule-r" aria-hidden="true"></span>

    <header class="cover-meta cover-meta-tl">
      <span class="mono">Mattman</span>
      <span class="mono">Music</span>
    </header>
    <header class="cover-meta cover-meta-tr">
      <span class="mono">București · MMVI</span>
      <span class="mono">Independent label</span>
    </header>

    <h1 class="cover-mark" data-mark>
      <span class="cover-mark-line">MATTMAN</span>
      <span class="cover-mark-line cover-mark-line-2">MUSIC</span>
    </h1>

    <footer class="cover-meta cover-meta-bl">
      <span class="mono">— Scroll ↓</span>
    </footer>
    <footer class="cover-meta cover-meta-br">
      <span class="mono">№ 01 / 06</span>
    </footer>
  </section>

  <!-- ============================== -->
  <!-- 02 — STATEMENT (monumental)     -->
  <!-- ============================== -->
  <section class="statement" id="statement">
    <span class="statement-rule" aria-hidden="true"></span>
    <div class="statement-meta">
      <span class="mono">— 02</span>
      <span class="mono">Statement</span>
    </div>

    <h2 class="statement-text" data-blur-text>
      <span class="bt-word">Independent</span>
      <span class="bt-word">since</span>
      <span class="bt-word">MMVI.</span>
      <span class="bt-word st-break">Label</span>
      <span class="bt-word">care</span>
      <span class="bt-word">a</span>
      <span class="bt-word">construit</span>
      <span class="bt-word">decenii</span>
      <span class="bt-word">de</span>
      <span class="bt-word st-em">hituri</span>
      <span class="bt-word st-break">din</span>
      <span class="bt-word">București,</span>
      <span class="bt-word">pentru</span>
      <span class="bt-word">o</span>
      <span class="bt-word">audiență</span>
      <span class="bt-word">globală.</span>
    </h2>

    <div class="statement-tally">
      <div class="tally-item">
        <span class="tally-num">225M+</span>
        <span class="mono tally-label">Vizualizări · Panama</span>
      </div>
      <div class="tally-item">
        <span class="tally-num">XX</span>
        <span class="mono tally-label">Ani de catalog</span>
      </div>
      <div class="tally-item">
        <span class="tally-num">IV</span>
        <span class="mono tally-label">Voci pe roster</span>
      </div>
      <div class="tally-item">
        <span class="tally-num">IX+</span>
        <span class="mono tally-label">Țări — viral abroad</span>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- 03 — ROSTER (cinematic spreads) -->
  <!-- ============================== -->
  <section class="roster" id="roster">
    <header class="roster-head">
      <span class="mono">— 03</span>
      <span class="mono">Roster</span>
    </header>

    {roster.map((r, i) => (
      <article class={`feature feature-${r.slug}`} data-feature>
        <div class="feature-frame">
          <div class="feature-media" data-cover-media>
            <img src={r.photo} alt={r.name} loading="lazy" class="feature-img" data-parallax-img />
          </div>
          <div class="feature-veil" aria-hidden="true"></div>
        </div>

        <span class="feature-rule" aria-hidden="true"></span>

        <div class="feature-folio">
          <span class="mono">№ {String(i + 1).padStart(2, '0')} / 04</span>
          <span class="mono">{r.role}</span>
        </div>

        <h3 class="feature-name" data-feature-name>
          <span>{r.name}</span>
        </h3>

        <div class="feature-text">
          <span class="mono feature-tagline">{r.tagline}</span>
          <p class="feature-bio">{r.bio}</p>
        </div>
      </article>
    ))}
  </section>

  <!-- ============================== -->
  <!-- 04 — CATALOG (architectural)    -->
  <!-- ============================== -->
  <section class="catalog" id="catalog" data-bg="light">
    <header class="catalog-head">
      <div class="catalog-meta">
        <span class="mono">— 04</span>
        <span class="mono">Catalog</span>
      </div>
      <h2 class="catalog-title">
        <span>Două decenii.</span>
        <span class="catalog-title-2">Douăsprezece pietre.</span>
      </h2>
    </header>

    <ol class="ledger">
      {tracks.map((t, i) => (
        <li class={`ledger-row ${t.highlight ? 'is-key' : ''}`} data-scramble-trigger>
          <span class="ledger-idx mono">{String(i + 1).padStart(2, '0')}</span>
          <span class="ledger-year mono">{t.year}</span>
          <span class="ledger-title">
            <span data-decrypt>{t.title}</span>
          </span>
          <span class="ledger-feat mono">{t.feat || ''}</span>
          <span class="ledger-note mono">{t.note || ''}</span>
        </li>
      ))}
    </ol>
  </section>

  <!-- ============================== -->
  <!-- 05 — CONTACT (architectural)    -->
  <!-- ============================== -->
  <section class="contact" id="contact">
    <header class="contact-head">
      <span class="mono">— 05</span>
      <span class="mono">Contact</span>
    </header>

    <h2 class="contact-mark" data-mark>
      <span class="cover-mark-line">CONTACT</span>
    </h2>

    <div class="contact-block">
      <a href="mailto:booking@mattmanmusic.com" class="contact-line hover-target">
        <span class="mono contact-tag">Booking · Management</span>
        <span class="contact-mail">booking@mattmanmusic.com</span>
      </a>
      <a href="mailto:hello@mattmanmusic.com" class="contact-line hover-target">
        <span class="mono contact-tag">Press · Label</span>
        <span class="contact-mail">hello@mattmanmusic.com</span>
      </a>
    </div>
  </section>

  <!-- ============================== -->
  <!-- COLOPHON                        -->
  <!-- ============================== -->
  <footer class="colophon">
    <span class="mono">Mattman Music · MMVI — MMXXVI</span>
    <a href="https://youtube.com/@mattmanmusic" target="_blank" rel="noopener" class="mono hover-target">YouTube ↗</a>
    <span class="mono">Site · <a href="https://grappes.ai" target="_blank" rel="noopener" class="hover-target">Grappes</a></span>
  </footer>
</Layout>

<style>
  /* ============================== */
  /*  GLOBAL                        */
  /* ============================== */
  body {
    background: var(--ink);
    color: var(--bone);
  }
  body.light { background: var(--bone); color: var(--ink); }
  ::selection { background: var(--brass); color: var(--ink); }

  .mono {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    line-height: 1.4;
  }

  /* ============================== */
  /*  NAV                           */
  /* ============================== */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: grid; grid-template-columns: 1fr auto;
    align-items: center; gap: 2rem;
    padding: 1.4rem var(--pad-x);
    pointer-events: none;
    mix-blend-mode: difference;
    color: var(--bone);
  }
  .nav > * { pointer-events: auto; }
  .nav-logo { order: 2; justify-self: end; }
  .nav-logo img { height: 26px; width: auto; filter: invert(1) brightness(0.96); }
  body.light .nav-logo img { filter: none; }
  .nav-links {
    order: 1;
    display: flex; gap: 1.4rem;
    justify-self: center;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
  }
  .nav-links a { transition: opacity 0.3s; opacity: 0.75; }
  .nav-links a:hover { opacity: 1; }

  @media (max-width: 820px) {
    .nav-links { display: none; }
    .nav { grid-template-columns: 1fr; }
    .nav-logo { justify-self: end; }
  }

  /* ============================== */
  /*  COVER                          */
  /* ============================== */
  .cover {
    position: relative;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    isolation: isolate;
  }
  .cover-frame {
    position: absolute; inset: 0;
    overflow: hidden;
    z-index: 0;
  }
  .cover-media {
    position: absolute;
    inset: -8% -4%;
    will-change: transform;
  }
  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: grayscale(0.35) contrast(1.08) brightness(0.9) saturate(0.85);
    animation: kenburns 22s ease-in-out infinite alternate;
  }
  @keyframes kenburns {
    0% { transform: scale(1.04) translate(0, 0); }
    100% { transform: scale(1.12) translate(-1%, -2%); }
  }
  .cover-veil {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(14,13,11,0.35) 0%, rgba(14,13,11,0.15) 35%, rgba(14,13,11,0.55) 75%, rgba(14,13,11,0.92) 100%),
      radial-gradient(ellipse at 50% 40%, rgba(14,13,11,0) 0%, rgba(14,13,11,0.5) 100%);
    z-index: 1;
    pointer-events: none;
  }

  /* Brâncuși thin column rules — vertical lines on margins */
  .cover-rule {
    position: absolute;
    top: clamp(6rem, 12vh, 9rem);
    bottom: clamp(4rem, 8vh, 6rem);
    width: 1px;
    background: linear-gradient(180deg, transparent 0%, var(--bone) 14%, var(--bone) 86%, transparent 100%);
    opacity: 0.32;
    z-index: 3;
  }
  .cover-rule-l { left: clamp(1.6rem, 3vw, 3rem); }
  .cover-rule-r { right: clamp(1.6rem, 3vw, 3rem); }

  .cover-meta {
    position: absolute;
    z-index: 4;
    display: flex; flex-direction: column;
    gap: 0.45em;
    color: var(--bone);
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    line-height: 1.4;
    opacity: 0.78;
  }
  .cover-meta-tl { top: clamp(4.2rem, 7vh, 6rem); left: clamp(2.8rem, 5vw, 5rem); }
  .cover-meta-tr { top: clamp(4.2rem, 7vh, 6rem); right: clamp(2.8rem, 5vw, 5rem); align-items: flex-end; text-align: right; }
  .cover-meta-bl { bottom: clamp(2.8rem, 5vh, 4rem); left: clamp(2.8rem, 5vw, 5rem); }
  .cover-meta-br { bottom: clamp(2.8rem, 5vh, 4rem); right: clamp(2.8rem, 5vw, 5rem); align-items: flex-end; }

  .cover-mark {
    position: absolute;
    inset: 0;
    z-index: 4;
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 0 clamp(2.8rem, 5vw, 5rem) clamp(4.5rem, 9vh, 8rem);
    pointer-events: none;
  }
  .cover-mark-line {
    font-family: 'Antonio', 'Inter', sans-serif;
    font-weight: 600;
    font-size: clamp(4rem, 16vw, 17rem);
    line-height: 0.86;
    letter-spacing: -0.025em;
    text-transform: uppercase;
    color: var(--bone);
    display: block;
    overflow: hidden;
    transform: translateY(105%);
    transition: transform 1.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .cover-mark-line-2 {
    color: transparent;
    -webkit-text-stroke: 1.5px var(--bone);
    margin-left: clamp(1.5rem, 6vw, 6rem);
    transition-delay: 0.18s;
  }
  [data-mark].is-in .cover-mark-line { transform: translateY(0); }

  @media (max-width: 720px) {
    .cover-rule { display: none; }
    .cover-meta-tl, .cover-meta-tr, .cover-meta-bl, .cover-meta-br {
      font-size: 0.5rem;
      letter-spacing: 0.18em;
      gap: 0.3em;
    }
    .cover-meta-tl, .cover-meta-bl { left: 1.2rem; }
    .cover-meta-tr, .cover-meta-br { right: 1.2rem; }
    .cover-mark { padding: 0 1.4rem 3.4rem; }
    .cover-mark-line { font-size: clamp(3.2rem, 19vw, 6rem); }
    .cover-mark-line-2 { margin-left: 1.2rem; }
  }

  /* ============================== */
  /*  STATEMENT                      */
  /* ============================== */
  .statement {
    position: relative;
    padding: clamp(7rem, 14vh, 12rem) clamp(2.8rem, 5vw, 5rem);
    display: grid;
    gap: clamp(3rem, 6vw, 6rem);
  }
  .statement-rule {
    position: absolute;
    top: 0; left: clamp(2.8rem, 5vw, 5rem); right: clamp(2.8rem, 5vw, 5rem);
    height: 1px;
    background: var(--bone);
    opacity: 0.18;
  }
  .statement-meta {
    display: flex; gap: 2.5rem;
    opacity: 0.62;
  }
  .statement-text {
    font-family: 'Antonio', 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(1.8rem, 4.4vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: -0.012em;
    text-transform: uppercase;
    max-width: 24ch;
  }
  .statement-text .st-em {
    color: var(--brass);
    font-weight: 600;
  }
  .statement-text .st-break::before {
    content: '\A';
    white-space: pre;
  }
  .statement-text .bt-word {
    margin-right: 0.22em;
  }

  .statement-tally {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 3vw, 3rem);
    border-top: 1px solid color-mix(in srgb, var(--bone) 18%, transparent);
    padding-top: clamp(1.5rem, 3vw, 2.5rem);
  }
  .tally-item {
    display: flex; flex-direction: column;
    gap: 0.6rem;
  }
  .tally-num {
    font-family: 'Antonio', sans-serif;
    font-weight: 500;
    font-size: clamp(2.4rem, 5.5vw, 5.5rem);
    line-height: 0.9;
    letter-spacing: -0.015em;
    color: var(--bone);
  }
  .tally-label { opacity: 0.55; max-width: 14ch; line-height: 1.4; }

  @media (max-width: 720px) {
    .statement-tally { grid-template-columns: 1fr 1fr; gap: 1.2rem; }
    .statement-text { font-size: clamp(1.4rem, 7vw, 2.4rem); max-width: none; }
  }

  /* ============================== */
  /*  ROSTER (cinematic features)    */
  /* ============================== */
  .roster {
    position: relative;
    border-top: 1px solid color-mix(in srgb, var(--bone) 14%, transparent);
  }
  .roster-head {
    display: flex; gap: 2.5rem;
    padding: clamp(3rem, 6vh, 5rem) clamp(2.8rem, 5vw, 5rem);
    opacity: 0.62;
  }

  .feature {
    position: relative;
    height: 100svh;
    min-height: 620px;
    overflow: hidden;
    isolation: isolate;
    border-top: 1px solid color-mix(in srgb, var(--bone) 14%, transparent);
  }
  .feature-frame {
    position: absolute; inset: 0;
    overflow: hidden;
    z-index: 0;
  }
  .feature-media {
    position: absolute; inset: -8% -4%;
    will-change: transform;
  }
  .feature-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 25%;
    filter: grayscale(0.4) contrast(1.1) brightness(0.82) saturate(0.8);
    animation: kenburns 26s ease-in-out infinite alternate;
  }
  /* slight per-feature variations so they don't feel identical */
  .feature-andrei .feature-img { object-position: center 18%; animation-duration: 24s; }
  .feature-georgiana .feature-img { object-position: center 22%; filter: grayscale(0.3) contrast(1.05) brightness(0.86) saturate(0.88); }
  .feature-emily .feature-img { object-position: center 30%; animation-duration: 28s; }
  .feature-veil {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(14,13,11,0.45) 0%, rgba(14,13,11,0.18) 30%, rgba(14,13,11,0.7) 78%, rgba(14,13,11,0.95) 100%),
      linear-gradient(90deg, rgba(14,13,11,0.45) 0%, rgba(14,13,11,0) 35%, rgba(14,13,11,0) 100%);
    z-index: 1;
  }

  .feature-rule {
    position: absolute;
    top: clamp(4rem, 8vh, 6rem); bottom: clamp(3rem, 6vh, 5rem);
    left: clamp(1.6rem, 3vw, 3rem);
    width: 1px;
    background: linear-gradient(180deg, transparent 0%, var(--bone) 18%, var(--bone) 82%, transparent 100%);
    opacity: 0.28;
    z-index: 3;
  }

  .feature-folio {
    position: absolute;
    top: clamp(4.2rem, 7vh, 6rem);
    left: clamp(2.8rem, 5vw, 5rem);
    right: clamp(2.8rem, 5vw, 5rem);
    z-index: 4;
    display: flex; justify-content: space-between;
    color: var(--bone);
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    opacity: 0.78;
  }

  .feature-name {
    position: absolute;
    z-index: 4;
    left: clamp(2.8rem, 5vw, 5rem);
    bottom: 38%;
    margin: 0;
    font-family: 'Antonio', sans-serif;
    font-weight: 500;
    font-size: clamp(3rem, 11vw, 12rem);
    line-height: 0.86;
    letter-spacing: -0.025em;
    text-transform: uppercase;
    color: var(--bone);
    overflow: hidden;
  }
  .feature-name span {
    display: block;
    transform: translateY(105%);
    transition: transform 1.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .feature[data-in] .feature-name span { transform: translateY(0); }

  .feature-text {
    position: absolute;
    z-index: 4;
    left: clamp(2.8rem, 5vw, 5rem);
    right: clamp(2.8rem, 5vw, 5rem);
    bottom: clamp(2.8rem, 5vh, 4rem);
    display: grid;
    grid-template-columns: 1fr minmax(0, 56ch) 1fr;
    gap: 2rem;
    align-items: end;
    color: var(--bone);
  }
  .feature-tagline {
    grid-column: 1;
    color: var(--brass);
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    align-self: end;
    opacity: 0.95;
  }
  .feature-bio {
    grid-column: 2;
    font-size: clamp(0.85rem, 1.05vw, 1.05rem);
    line-height: 1.55;
    max-width: 58ch;
    opacity: 0.92;
  }

  @media (max-width: 820px) {
    .feature-rule { display: none; }
    .feature-name { font-size: clamp(2.4rem, 14vw, 5rem); bottom: 50%; }
    .feature-text {
      grid-template-columns: 1fr;
      bottom: 2rem;
      left: 1.4rem; right: 1.4rem;
    }
    .feature-tagline { grid-column: auto; }
    .feature-bio { grid-column: auto; font-size: 0.78rem; line-height: 1.5; }
    .feature-folio { left: 1.4rem; right: 1.4rem; font-size: 0.5rem; letter-spacing: 0.18em; }
  }

  /* ============================== */
  /*  CATALOG (architectural)        */
  /* ============================== */
  .catalog {
    padding: clamp(5rem, 10vh, 9rem) clamp(2.8rem, 5vw, 5rem);
  }
  .catalog-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    gap: 2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 22%, transparent);
    padding-bottom: clamp(2rem, 4vh, 3rem);
    margin-bottom: clamp(2rem, 4vh, 3rem);
  }
